		<script src="https://munkavedelem-es-tuzvedelem.hu/wp-content/plugins/mailster/assets/js/form.min.js?ver=2.4.14"></script>
		<script>
		jQuery(function($) {		
			
			// Vars
							var cookieName = 'aurapro_munkavedelem';
						
			// Get cookie
			function getCookie(cname) {
				var name = cname + "=";
				var ca = document.cookie.split(';');
				for(var i=0; i<ca.length; i++) {
					var c = ca[i];
					while (c.charAt(0)==' ') c = c.substring(1);
					if (c.indexOf(name) == 0) return c.substring(name.length,c.length);
				}
				return "";
			}
		
			// Set cookie
			function setCookie(cname, cvalue, exdays) {
				var d = new Date();
				d.setTime(d.getTime() + (exdays*24*60*60*1000));
				var expires = "expires="+d.toUTCString();
				document.cookie = cname + "=" + cvalue + ";  path=/; " + expires;
			}
			
			// Mouse leave action
			if (!getCookie(cookieName)) {
				document.addEventListener('mouseleave', function(e){
					if (e.clientY < 0) {
						$.magnificPopup.open({
							items: {
								src: '#exitpopup' 
							},
							closeOnBgClick: false,
							type: 'inline',
							callbacks: {
								close: function(){
									$.cookie(cookieName, 1, { 
										expires: 1,
										path: '/'
									});
									
									//console.log('');
									
									location.reload();
								}
							},
							disableOn: function() {
								if ($(window).width() < 600) {
									return false;
								}
								return true;
							}
						}, 0);
					}
				}, false);
			}
			
			//$.removeCookie('aurapro_munkavedelem', { path: '/' });
			
					});
		</script>
			
		<script type="text/javascript" src="//cdn.jsdelivr.net/jquery.slick/1.6.0/slick.min.js"></script>

		<script>
		jQuery(document).ready(function($) {

			$('.toggle').click(function(event) {
				$(this).closest('div').find('ul').slideToggle(300);
				return false;
			});

			$('#nav-toggle').click(function(event) {
				$(this).toggleClass('active');
				$('.rwd_menu').slideToggle(300);
				return false;
			});

			$('.partners').slick({
				dots: true,
				infinite: true,
				speed: 300,
				nextArrow: '<i class="ion-ios-arrow-thin-right"></i>',
				prevArrow: '<i class="ion-ios-arrow-thin-left"></i>',
				slidesToShow: 10,
				slidesToScroll: 10,
				responsive: [
					{
						breakpoint: 1024,
						settings: {
							slidesToShow: 10,
							slidesToScroll: 10,
							infinite: true,
							dots: true
						}
					},
					{
						breakpoint: 600,
						settings: {
							slidesToShow: 5,
							slidesToScroll: 5
						}
					},
					{
						breakpoint: 480,
						settings: {
							slidesToShow: 3,
							slidesToScroll: 3
						}
					}
				]
			});

			$(window).scroll(function() {
			if ($(this).scrollTop() > 1){  
				$('#topline').addClass("sticky");
			  }
			  else{
				$('#topline').removeClass("sticky");
			  }
			});

			$('.expand').click(function(event) {
				$('.toggle_used').toggleClass('used');
				return false;

			});

			if ($('.content').length) {
			   /*$('html, body').animate({
					scrollTop: $('.content').offset().top - 100
				}, 2000);*/
			}


			$('a[href*="#"]').not('[href="#"]').not('[href="#0"]').click(function(event) {
				if (location.pathname.replace(/^\//, '') == this.pathname.replace(/^\//, '') && location.hostname == this.hostname) {
					var target = $(this.hash);
					target = target.length ? target : $('[name=' + this.hash.slice(1) + ']');
					
					if (target.length) {
						event.preventDefault();
						$('html, body').animate({
							scrollTop: target.offset().top - 100
						}, 1000, function() {
							var $target = $(target);
							$target.focus();
							if ($target.is(":focus")) { 
								return false;
							} else {
								$target.attr('tabindex','-1');
								$target.focus();
							};
						});
					}
				}
			});
		});	
		
		// Széchenyi2020 AJAX
		jQuery(function($) { 
			$('.szechenyi2020 .close').click(function() { 
				$.ajax({
					type: "POST",
					url: '/wp-admin/admin-ajax.php',
					data: {
						action: 'szechenyi2020_logo_hook',
						cookie: 'closed_aurapro_szechenyi2020',
					},
					success: function () {
						$('.szechenyi2020').fadeOut();
					},
				});
			});
		});		
		
		// Contact form 7
		document.addEventListener('wpcf7mailsent', function(event) {
			if (event.detail.contactFormId == '1249') { 
				location = "https://munkavedelem-es-tuzvedelem.hu/home-office-visszahivas-keres/";
				
			} else if (event.detail.contactFormId == '846') { 
				location = "https://munkavedelem-es-tuzvedelem.hu/koszonjuk-kepzesre-jelentkezes/";
			
			} else if (event.detail.contactFormId == '682') { 
				var n = event.detail.inputs[0].value, 
					e = event.detail.inputs[1].value;
				
				location = "https://munkavedelem-es-tuzvedelem.hu/thank-you-request-offer/";
			
			} else {
				location = "https://munkavedelem-es-tuzvedelem.hu/koszonjuk-arajanlat-kereset";
				 alert(event);
			}
		}, false);
		</script>
	</body>
</html>
