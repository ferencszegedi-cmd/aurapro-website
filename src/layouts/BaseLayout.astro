---
import '../styles/global.css';
import { ui, getAlternatePath, hasAlternate, type Lang } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noIndex?: boolean;
  lang?: Lang;
}

const {
  title,
  description,
  canonical,
  ogImage = '/og-image.jpg',
  noIndex = false,
  lang = 'hu',
} = Astro.props;

const t = ui[lang];
const ogLocale = lang === 'en' ? 'en_US' : 'hu_HU';

const siteUrl = 'https://www.aurapro.hu';
const fullCanonical = canonical ? `${siteUrl}${canonical}` : Astro.url.href;

// hreflang: csak azoknál az oldalaknál, amelyeknek van párja a másik nyelven.
const pathname = Astro.url.pathname;
const showHreflang = hasAlternate(pathname);
const huHref = `${siteUrl}${getAlternatePath(pathname, 'hu')}`;
const enHref = `${siteUrl}${getAlternatePath(pathname, 'en')}`;

// Build-jelölő: a Vercel build-időben beállítja a commit SHA-t (deploy-ellenőrzéshez).
const buildCommit = process.env.VERCEL_GIT_COMMIT_SHA?.slice(0, 7) ?? 'dev';

// P0-1: Vercel preview deploymentokon noindex (duplicate content védelem).
// Vercel automatikusan beállítja a VERCEL_ENV-et: "production" | "preview" | "development".
// Statikus build-nél ez build-időben dől el, ezért env-alapon kell vizsgálni.
const vercelEnv = import.meta.env.VERCEL_ENV; // production | preview | development | undefined (lokál)
const isPreviewBuild = vercelEnv === 'preview';
const effectiveNoIndex = noIndex || isPreviewBuild;

// P0-2: GA4 + Google Ads (csak ha az env változók be vannak állítva – addig stub-ban marad).
// Vercel projektbe: PUBLIC_GA4_ID, PUBLIC_ADS_CONVERSION_ID
const GA4_ID = import.meta.env.PUBLIC_GA4_ID;
const ADS_ID = import.meta.env.PUBLIC_ADS_CONVERSION_ID;
const trackingEnabled = !!GA4_ID;

// P0-4: ProfessionalService schema – minden oldalra (override-olható lent a slot-tal)
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'Aurapro Kft.',
  url: siteUrl,
  logo: `${siteUrl}/logo.svg`,
  image: `${siteUrl}/logo.jpg`,
  description: t.footer.tagline,
  telephone: '+36704098764',
  email: 'iroda@aurapro.hu',
  priceRange: '$$',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Gyár utca 2.',
    addressLocality: 'Budaörs',
    postalCode: '2040',
    addressCountry: 'HU',
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '08:00',
      closes: '17:00',
    },
  ],
  areaServed: { '@type': 'Country', name: 'Hungary' },
  sameAs: [],
};
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="x-build-commit" content={buildCommit} />
  <title>{title}</title>
  <meta name="description" content={description} />
  {effectiveNoIndex && <meta name="robots" content="noindex, nofollow" />}
  <link rel="canonical" href={fullCanonical} />
  {showHreflang && (
    <Fragment>
      <link rel="alternate" hreflang="hu" href={huHref} />
      <link rel="alternate" hreflang="en" href={enHref} />
      <link rel="alternate" hreflang="x-default" href={huHref} />
    </Fragment>
  )}

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`${siteUrl}${ogImage}`} />
  <meta property="og:url" content={fullCanonical} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content={ogLocale} />

  <!-- Fonts: P0-5 KÉSZ – self-hosted woff2 (latin+latin-ext), @font-face a global.css-ben.
       Preload csak az above-the-fold súlyokra (heading 700 + body 400). -->
  <link rel="preload" as="font" type="font/woff2" href="/fonts/montserrat-700.woff2" crossorigin />
  <link rel="preload" as="font" type="font/woff2" href="/fonts/inter-400.woff2" crossorigin />

  <!-- Favicon – ?v=2 cache-bust hogy a böngészők az új ikont töltsék be -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png?v=2" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=2" />

  <!-- P0-4: ProfessionalService JSON-LD (minden oldalon) -->
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

  {trackingEnabled && (
    <Fragment>
      {/* P0-2: gtag.js – Consent Mode v2 default DENIED, aurapro_applyConsent hív update-et */}
      <script is:inline define:vars={{ GA4_ID, ADS_ID }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){ dataLayer.push(arguments); }
        window.gtag = gtag;
        gtag('consent', 'default', {
          ad_storage: 'denied',
          analytics_storage: 'denied',
          ad_user_data: 'denied',
          ad_personalization: 'denied',
        });
        gtag('js', new Date());
        gtag('config', GA4_ID, { anonymize_ip: true });
        if (ADS_ID) gtag('config', ADS_ID);
      </script>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID}`}></script>
    </Fragment>
  )}

  <slot name="head" />
</head>
<body class="bg-white antialiased">
  <slot />

  <!-- Cookie banner – P1-3: keskeny, sticky bar fölé NEM kerül (z-50 helyett z-30, mobil sticky bar z-40) -->
  <div id="cookie-banner" class="fixed bottom-0 left-0 right-0 z-30 hidden lg:bottom-0 bottom-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-2 lg:pb-4">
      <div class="bg-heading rounded-lg lg:rounded-xl px-4 py-3 sm:px-6 sm:py-4 flex flex-col sm:flex-row items-center gap-3 shadow-2xl">
        <p class="text-white/90 text-sm flex-1">
          {t.cookie.text}
          <a href="/adatvedelem/" class="underline hover:text-white">{t.cookie.details}</a>
        </p>
        <div class="flex gap-2 shrink-0">
          <button id="cookie-reject" class="px-3 py-1.5 text-sm text-white/70 hover:text-white transition-colors">
            {t.cookie.reject}
          </button>
          <button id="cookie-accept" class="px-4 py-1.5 bg-teal text-white text-sm font-semibold rounded-md hover:bg-teal-dark transition-colors">
            {t.cookie.accept}
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll animations -->
  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('[data-animate]').forEach((el) => observer.observe(el));
  </script>

  <!-- Cookie logic + P0-2 consent hook (gtag placeholder, aktiválódik ha PUBLIC_GA4_ID megérkezik) -->
  <script>
    const banner = document.getElementById('cookie-banner');
    const consent = localStorage.getItem('cookie-consent');

    // Globális hook – consent állapot változásnál hív
    (window as any).aurapro_applyConsent = function (granted: boolean) {
      if (typeof (window as any).gtag === 'function') {
        (window as any).gtag('consent', 'update', {
          ad_storage: granted ? 'granted' : 'denied',
          analytics_storage: granted ? 'granted' : 'denied',
          ad_user_data: granted ? 'granted' : 'denied',
          ad_personalization: granted ? 'granted' : 'denied',
        });
      }
    };

    if (!consent && banner) {
      banner.classList.remove('hidden');
    } else if (consent === 'accepted') {
      (window as any).aurapro_applyConsent?.(true);
    }

    document.getElementById('cookie-accept')?.addEventListener('click', () => {
      localStorage.setItem('cookie-consent', 'accepted');
      banner?.classList.add('hidden');
      (window as any).aurapro_applyConsent?.(true);
    });

    document.getElementById('cookie-reject')?.addEventListener('click', () => {
      localStorage.setItem('cookie-consent', 'rejected');
      banner?.classList.add('hidden');
      (window as any).aurapro_applyConsent?.(false);
    });
  </script>

  <!-- Telefon-kattintás telemetria (másodlagos konverzió az Ads-hez) -->
  <script>
    document.addEventListener('click', (e) => {
      const target = e.target as Element | null;
      const link = target?.closest?.('a[href^="tel:"]') as HTMLElement | null;
      if (!link) return;
      if (typeof (window as any).gtag === 'function') {
        (window as any).gtag('event', 'phone_click', {
          cta: link.dataset.cta ?? 'unknown',
          page_path: window.location.pathname,
        });
      }
    });
  </script>
</body>
</html>
