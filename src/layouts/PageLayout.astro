---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileStickyBar from '../components/MobileStickyBar.astro';
import ExitIntentPopup from '../components/ExitIntentPopup.astro';
import type { Lang } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  noIndex?: boolean;
  lang?: Lang;
}

const { title, description, canonical, noIndex = false, lang = 'hu' } = Astro.props;
---

<BaseLayout title={title} description={description} canonical={canonical} noIndex={noIndex} lang={lang}>
  <Fragment slot="head"><slot name="head" /></Fragment>
  <Header lang={lang} />
  <main>
    <slot />
  </main>
  <Footer lang={lang} />
  <MobileStickyBar lang={lang} />
  <ExitIntentPopup lang={lang} />
</BaseLayout>
