---
import { ui, navItems, getAlternatePath, type Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}
const { lang = 'hu' } = Astro.props;
const t = ui[lang];
const items = navItems(lang);
const homeHref = lang === 'en' ? '/en/' : '/';
const contactHref = lang === 'en' ? '/en/contact/' : '/kapcsolat/';

// Nyelvváltó: az aktuális oldal párja a másik nyelven.
const path = Astro.url.pathname;
const huHref = getAlternatePath(path, 'hu');
const enHref = getAlternatePath(path, 'en');
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-border" id="site-header">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-36 lg:h-44">
      <!-- Logo – logo.jpg (a designer eredetije, jó arányokkal) mix-blend-multiply-val -->
      <a href={homeHref} class="shrink-0">
        <img src="/logo.jpg" alt="Aurapro – safety first" class="h-32 lg:h-[9.5rem] mix-blend-multiply" />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
        {items.map((item) => (
          item.children ? (
            <div class="relative group">
              <button class="px-3 py-2 text-[15px] font-medium text-body hover:text-teal transition-colors flex items-center gap-1">
                {item.label}
                <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div class="absolute top-full left-0 pt-1 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all">
                <div class="bg-white rounded-lg shadow-lg border border-border py-2 min-w-[200px]">
                  {item.children.map((child) => (
                    <a href={child.href} class="block px-4 py-2 text-sm text-body hover:bg-teal-light hover:text-teal transition-colors">
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a href={item.href} class="px-3 py-2 text-[15px] font-medium text-body hover:text-teal transition-colors">
              {item.label}
            </a>
          )
        ))}
      </nav>

      <!-- CTA + nyelv (telefonszám eltávolítva a desktop header-ből – kompaktabb elrendezés) -->
      <div class="hidden lg:flex items-center gap-4">
        <a href={contactHref} class="inline-flex items-center px-5 py-2.5 bg-orange text-white font-heading font-semibold text-sm rounded-lg hover:bg-orange-dark transition-colors">
          {t.header.quote}
        </a>

        {/* Nyelv-választó – az aktív nyelv kiemelve, a másik link a párra */}
        <div class="flex items-center gap-1.5 pl-2 border-l border-border">
          {lang === 'hu' ? (
            <span aria-label="Magyar nyelv (aktuális)"
              class="inline-block w-7 h-5 rounded overflow-hidden ring-2 ring-teal shadow-sm">
              <img src="/images/flags/hu.svg" alt="Magyar" class="w-full h-full block" />
            </span>
          ) : (
            <a href={huHref} aria-label="Váltás magyarra" title="Magyar"
              class="inline-block w-7 h-5 rounded overflow-hidden ring-1 ring-border shadow-sm hover:ring-teal transition-all">
              <img src="/images/flags/hu.svg" alt="Magyar" class="w-full h-full block" />
            </a>
          )}
          {lang === 'en' ? (
            <span aria-label="English (current)"
              class="inline-block w-7 h-5 rounded overflow-hidden ring-2 ring-teal shadow-sm">
              <img src="/images/flags/gb.svg" alt="English" class="w-full h-full block" />
            </span>
          ) : (
            <a href={enHref} aria-label="Switch to English" title="English"
              class="inline-block w-7 h-5 rounded overflow-hidden ring-1 ring-border shadow-sm hover:ring-teal transition-all">
              <img src="/images/flags/gb.svg" alt="English" class="w-full h-full block" />
            </a>
          )}
        </div>
      </div>

      <!-- Mobil: nyelv-választó mindig láthatóan a fejlécsorban + menü gomb -->
      <div class="lg:hidden flex items-center gap-3">
        <div class="flex items-center gap-1.5">
          {lang === 'hu' ? (
            <span aria-label="Magyar nyelv (aktuális)"
              class="inline-block w-7 h-5 rounded overflow-hidden ring-2 ring-teal shadow-sm">
              <img src="/images/flags/hu.svg" alt="Magyar" class="w-full h-full block" />
            </span>
          ) : (
            <a href={huHref} aria-label="Váltás magyarra" title="Magyar"
              class="inline-block w-7 h-5 rounded overflow-hidden ring-1 ring-border shadow-sm hover:ring-teal transition-all">
              <img src="/images/flags/hu.svg" alt="Magyar" class="w-full h-full block" />
            </a>
          )}
          {lang === 'en' ? (
            <span aria-label="English (current)"
              class="inline-block w-7 h-5 rounded overflow-hidden ring-2 ring-teal shadow-sm">
              <img src="/images/flags/gb.svg" alt="English" class="w-full h-full block" />
            </span>
          ) : (
            <a href={enHref} aria-label="Switch to English" title="English"
              class="inline-block w-7 h-5 rounded overflow-hidden ring-1 ring-border shadow-sm hover:ring-teal transition-all">
              <img src="/images/flags/gb.svg" alt="English" class="w-full h-full block" />
            </a>
          )}
        </div>
        <button
          class="p-2 text-body hover:text-teal"
          aria-label="Open menu"
          id="mobile-menu-btn"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu (görgethető, hogy a hosszú lista alja is elérhető legyen) -->
  <div class="lg:hidden hidden max-h-[calc(100dvh-9rem)] overflow-y-auto" id="mobile-menu">
    <div class="px-4 py-4 border-t border-border bg-white space-y-1">
      {items.map((item) => (
        item.children ? (
          <div>
            <div class="px-3 py-2 text-sm font-semibold text-muted uppercase tracking-wide">{item.label}</div>
            {item.children.map((child) => (
              <a href={child.href} class="block px-6 py-2 text-body hover:text-teal transition-colors">
                {child.label}
              </a>
            ))}
          </div>
        ) : (
          <a href={item.href} class="block px-3 py-2 text-body hover:text-teal transition-colors">
            {item.label}
          </a>
        )
      ))}
      <div class="pt-4 space-y-3">
        <a href="tel:+36704098764" class="block text-center text-teal font-semibold">
          +36 70 409 8764
        </a>
        <a href={contactHref} class="block text-center px-5 py-3 bg-orange text-white font-heading font-semibold rounded-lg hover:bg-orange-dark transition-colors">
          {t.header.quote}
        </a>

        {/* Nyelv-választó mobilon */}
        <div class="flex items-center justify-center gap-2 pt-2 border-t border-border">
          <span class="text-xs text-muted mr-1">{lang === 'en' ? 'Language:' : 'Nyelv:'}</span>
          {lang === 'hu' ? (
            <span aria-label="Magyar nyelv (aktuális)"
              class="inline-block w-8 h-6 rounded overflow-hidden ring-2 ring-teal shadow-sm">
              <img src="/images/flags/hu.svg" alt="Magyar" class="w-full h-full block" />
            </span>
          ) : (
            <a href={huHref} aria-label="Váltás magyarra" title="Magyar"
              class="inline-block w-8 h-6 rounded overflow-hidden ring-1 ring-border shadow-sm hover:ring-teal transition-all">
              <img src="/images/flags/hu.svg" alt="Magyar" class="w-full h-full block" />
            </a>
          )}
          {lang === 'en' ? (
            <span aria-label="English (current)"
              class="inline-block w-8 h-6 rounded overflow-hidden ring-2 ring-teal shadow-sm">
              <img src="/images/flags/gb.svg" alt="English" class="w-full h-full block" />
            </span>
          ) : (
            <a href={enHref} aria-label="Switch to English" title="English"
              class="inline-block w-8 h-6 rounded overflow-hidden ring-1 ring-border shadow-sm hover:ring-teal transition-all">
              <img src="/images/flags/gb.svg" alt="English" class="w-full h-full block" />
            </a>
          )}
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
