---
interface Props {
  title: string;
  titleLine2?: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
  compact?: boolean;
  heroImage?: string;
  heroImageAlt?: string;
}

const {
  title,
  titleLine2,
  subtitle,
  ctaText = 'Ingyenes ajánlat 24 órán belül',
  ctaHref = '/kapcsolat/',
  secondaryCtaText,
  secondaryCtaHref,
  compact = false,
  heroImage,
  heroImageAlt = '',
} = Astro.props;
---

<section class:list={["bg-[#919196] text-white relative overflow-hidden", compact ? "py-16 lg:py-20" : "py-20 lg:py-32"]}>
  {heroImage && (
    <div class="hidden lg:block absolute inset-y-0 right-0 w-1/2 pointer-events-none" aria-hidden="true">
      <img
        src={heroImage}
        alt={heroImageAlt}
        class="absolute inset-0 w-full h-full object-cover object-[75%_center]"
        loading="eager"
        style="mask-image: linear-gradient(to right, transparent, black 30%); -webkit-mask-image: linear-gradient(to right, transparent, black 30%);"
      />
    </div>
  )}
  <div class:list={["relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8", heroImage ? "" : "text-center"]}>
    <div class:list={[heroImage ? "lg:max-w-2xl text-center lg:text-left" : "text-center"]}>
      <h1 class:list={["font-heading font-bold text-3xl sm:text-4xl lg:text-5xl text-white leading-tight", heroImage ? "" : "max-w-4xl mx-auto"]}>
        {title}
        {titleLine2 && <br />}
        {titleLine2 && <span>{titleLine2}</span>}
      </h1>
      {subtitle && (
        <p class:list={["mt-6 text-lg lg:text-xl text-white/80", heroImage ? "" : "max-w-2xl mx-auto"]}>
          {subtitle}
        </p>
      )}
      <div class:list={["mt-8 flex flex-col sm:flex-row items-center gap-4", heroImage ? "justify-center lg:justify-start" : "justify-center"]}>
        <a href={ctaHref} class="inline-flex items-center px-8 py-4 bg-orange text-white font-heading font-bold text-lg rounded-lg hover:bg-orange-dark transition-colors shadow-lg hover:shadow-xl">
          {ctaText}
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        {secondaryCtaText && secondaryCtaHref && (
          <a href={secondaryCtaHref} class="inline-flex items-center px-8 py-4 border-2 border-white/30 text-white font-heading font-semibold text-lg rounded-lg hover:bg-white/10 transition-colors">
            {secondaryCtaText}
          </a>
        )}
      </div>
    </div>
  </div>
</section>
