---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  /** Kis kapitális felirat a címsor fölött (pl. szolgáltatás-lista) */
  eyebrow?: string;
  title: string;
  /** Második címsor-sor – highlightLine2-vel narancs kiemelést kap */
  titleLine2?: string;
  highlightLine2?: boolean;
  subtitle?: string;
  /** Pipás trust-chipek a címsor alatt (a subtitle helyett vagy mellett) */
  chips?: string[];
  ctaText?: string;
  ctaHref?: string;
  /** Telefon-megjelenítés: NEM kattintható (Ferenc-döntés), és nem is néz ki gombnak */
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
  secondaryCtaSubtext?: string;
  compact?: boolean;
  /** astro:assets import (src/assets/images/...) – build-kor AVIF/WebP variánsok készülnek */
  heroImage?: ImageMetadata;
  heroImageAlt?: string;
}

const {
  eyebrow,
  title,
  titleLine2,
  highlightLine2 = false,
  subtitle,
  chips,
  ctaText = 'Ingyenes ajánlat 24 órán belül',
  ctaHref = '/kapcsolat/',
  secondaryCtaText,
  secondaryCtaHref,
  secondaryCtaSubtext,
  compact = false,
  heroImage,
  heroImageAlt = '',
} = Astro.props;
---

<section class:list={["hero-gradient text-white relative overflow-hidden", compact ? "py-16 lg:py-20" : "py-20 lg:py-32"]}>
  <div class="absolute inset-0 hero-pattern pointer-events-none" aria-hidden="true"></div>
  {heroImage && (
    <div class="hidden lg:block absolute inset-y-0 right-0 w-1/2 pointer-events-none" aria-hidden="true">
      <Picture
        src={heroImage}
        alt={heroImageAlt}
        formats={['avif', 'webp']}
        widths={[768, 1280, 1920]}
        sizes="50vw"
        class="absolute inset-0 w-full h-full object-cover object-[25%_center]"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        style="mask-image: linear-gradient(to right, transparent, black 30%); -webkit-mask-image: linear-gradient(to right, transparent, black 30%);"
      />
    </div>
  )}
  <div class:list={["relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8", heroImage ? "" : "text-center"]}>
    <div class:list={[heroImage ? "lg:max-w-2xl text-center lg:text-left" : "text-center"]}>
      {eyebrow && (
        <p class="font-heading font-semibold text-sm lg:text-base tracking-[0.18em] uppercase text-white/75">
          {eyebrow}
        </p>
      )}
      <h1 class:list={["font-heading font-bold text-3xl sm:text-4xl lg:text-5xl text-white leading-tight", eyebrow ? "mt-4" : "", heroImage ? "" : "max-w-4xl mx-auto"]}>
        {title}
        {titleLine2 && <br />}
        {titleLine2 && <span class:list={[highlightLine2 ? "text-orange" : ""]}>{titleLine2}</span>}
      </h1>
      {subtitle && (
        <p class:list={["mt-6 text-lg lg:text-xl text-white/80", heroImage ? "" : "max-w-2xl mx-auto"]}>
          {subtitle}
        </p>
      )}
      {chips && chips.length > 0 && (
        <div class:list={["mt-6 flex flex-wrap gap-2", heroImage ? "justify-center lg:justify-start" : "justify-center"]}>
          {chips.map((chip) => (
            <span class="inline-flex items-center gap-1.5 rounded-full bg-white/10 border border-white/25 px-3 py-1.5 text-xs sm:text-sm font-semibold text-white">
              <svg class="w-3.5 h-3.5 text-orange shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
              </svg>
              {chip}
            </span>
          ))}
        </div>
      )}
      <div class:list={["mt-8 flex flex-col sm:flex-row items-center gap-5", heroImage ? "justify-center lg:justify-start" : "justify-center"]}>
        <a href={ctaHref} class="inline-flex items-center px-8 py-4 bg-orange text-white font-heading font-bold text-lg rounded-lg hover:bg-orange-dark transition-colors shadow-lg hover:shadow-xl">
          {ctaText}
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        {secondaryCtaText && (
          secondaryCtaHref ? (
            <a href={secondaryCtaHref} class="inline-flex flex-col items-center px-8 py-4 border-2 border-white/30 text-white font-heading font-semibold text-lg rounded-lg hover:bg-white/10 transition-colors">
              <span>{secondaryCtaText}</span>
              {secondaryCtaSubtext && <span class="text-[1.1rem] font-normal text-white/80 mt-1">{secondaryCtaSubtext}</span>}
            </a>
          ) : (
            <div class="inline-flex flex-col items-center lg:items-start text-white">
              <span class="inline-flex items-center gap-2 font-heading font-bold text-xl lg:text-2xl">
                <svg class="w-5 h-5 lg:w-6 lg:h-6 text-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
                {secondaryCtaText}
              </span>
              {secondaryCtaSubtext && <span class="text-white/75 text-sm mt-1">{secondaryCtaSubtext}</span>}
            </div>
          )
        )}
      </div>
    </div>
  </div>
</section>
