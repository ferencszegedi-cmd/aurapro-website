---
import { ui, type Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}
const { lang = 'hu' } = Astro.props;
const s = ui[lang].stats;
const stats = [
  { number: '~20', label: s.years },
  { number: '30+', label: s.experts },
  { number: '48+', label: s.refs },
  { number: '0', label: s.fines },
];
---

<section class="py-12 lg:py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 text-center">
      {stats.map((stat, i) => (
        <div data-animate data-animate-delay={i + 1}>
          <div class="font-heading font-bold text-4xl lg:text-5xl text-teal">{stat.number}</div>
          <div class="mt-2 text-muted text-sm lg:text-base">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
