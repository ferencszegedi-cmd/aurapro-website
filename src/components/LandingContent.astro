---
// P1-4 + CRO Fázis 2: Google Ads landing oldalak közös tartalom-komponense.
// NINCS navigáció, egy cél: wizard-kitöltés vagy telefonhívás.
// Mobil sorrend: tömör H1 + trust-chipek + WIZARD (above the fold) → bullets → többi.
import QuoteWizard from './QuoteWizard.astro';
import FaqAccordion from './FaqAccordion.astro';

interface Step {
  title: string;
  desc: string;
}

interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  /** Hero bal oszlop nagy címsora */
  headline: string;
  /** Hero alcím a headline alatt */
  subhead: string;
  /** Hero bullet-előnyök (4 db ajánlott) */
  bullets: string[];
  /** "Amit kap" 4 lépés */
  steps: Step[];
  /** Testimonial idézet */
  quote: string;
  /** Testimonial szerző (név + cég) */
  quoteAuthor: string;
  /** Form data-form forrás-azonosító (analytics) */
  formSource: string;
  /** lead.ts service enum értéke (a wizard 1. lépését átugorja) */
  service: 'munkavedelem' | 'tuzvedelem' | 'kornyezetvedelem' | 'komplex' | 'egyeb';
  /** Kifogáskezelő FAQ – ha nincs megadva, az alap enterprise-lista jelenik meg */
  faqItems?: FaqItem[];
}

const { headline, subhead, bullets, steps, quote, quoteAuthor, formSource, service, faqItems } =
  Astro.props;

const PHONE_DISPLAY = '+36 70 409 8764';
const PHONE_TEL = '+36704098764';

// Alap kifogáskezelő FAQ (felülírható a faqItems proppal)
const defaultFaq: FaqItem[] = [
  {
    question: 'Mennyibe kerül a szolgáltatás?',
    answer:
      'Minden ajánlatunk személyre szabott: a létszám, a telephelyek száma és a tevékenység kockázati szintje határozza meg. Ingyenes helyszíni felmérés után 24 órán belül konkrét, átlátható ajánlatot adunk – kötelezettségmentesen.',
  },
  {
    question: 'Mennyi idő alatt tudnak kezdeni?',
    answer:
      'Szerződéskötés után jellemzően 1–2 héten belül megkezdjük a munkát. Sürgős esetben – például hatósági határidő vagy ellenőrzés előtt – soron kívül is tudunk kapacitást biztosítani, 30 szakértőnk országos lefedettséggel dolgozik.',
  },
  {
    question: 'Mi történik az ajánlatkérés után?',
    answer:
      '24 órán belül visszahívjuk. Egyeztetünk egy ingyenes helyszíni felmérést, ahol megismerjük a cég működését, majd személyre szabott ajánlatot készítünk. A felmérés semmilyen kötelezettséggel nem jár.',
  },
  {
    question: 'Mi van, ha mégis bírságot kapunk?',
    answer:
      'Az általunk gondozott területen kapott bírságot 40 millió Ft-ig megtérítjük – ez a piacon egyedülálló bírsággarancia. Közel 20 év alatt egyetlen partnerünk sem kapott bírságot, így erre még sosem volt szükség.',
  },
  {
    question: 'Nagyvállalatokkal is dolgoznak?',
    answer:
      'Kifejezetten erre specializálódtunk. 48+ partnerünk jelentős része 100 fő feletti vállalat – köztük az Audi, a Siemens, a Richter és a Primark –, több telephelyes működéssel. A modellünk nagy szervezeteknél a leghatékonyabb.',
  },
];

const faq = faqItems ?? defaultFaq;

// 12 ismert nagyvállalati logó a grayscale bizalmi sávhoz (a public/referenciak/ alól)
const trustLogos = [
  { name: 'Audi', img: '/referenciak/audi.jpg' },
  { name: 'Siemens', img: '/referenciak/siemens.jpg' },
  { name: 'Richter Gedeon', img: '/referenciak/richter.jpg' },
  { name: 'DM', img: '/referenciak/dm.jpg' },
  { name: 'Primark', img: '/referenciak/primark.jpg' },
  { name: 'Porsche', img: '/referenciak/porsche.jpg' },
  { name: 'Egis', img: '/referenciak/egis.jpg' },
  { name: 'Libri', img: '/referenciak/libri.jpg' },
  { name: 'Pepco', img: '/referenciak/pepco.jpg' },
  { name: 'CCC', img: '/referenciak/ccc.jpg' },
  { name: 'BNP Paribas', img: '/referenciak/bnp.jpg' },
  { name: 'Budapest Közút', img: '/referenciak/budapest-kozut.jpg' },
];

const trustChips = [
  '40M Ft bírsággarancia',
  '0 bírság közel 20 év alatt',
  '30 szakértő országszerte',
];
---

<!-- (2) HERO – mobil: H1 + chipek + WIZARD a hajtás fölött; desktop: kétoszlopos -->
<section class="bg-gradient-to-br from-teal-light to-white py-8 lg:py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-x-14 gap-y-6 lg:gap-y-8 items-start">
      <!-- A: headline + subhead + trust-chipek (mobil: 1.) -->
      <div>
        <h1 class="font-heading font-bold text-3xl sm:text-4xl lg:text-5xl text-heading leading-tight">
          {headline}
        </h1>
        <p class="mt-3 lg:mt-4 text-base lg:text-lg text-body leading-relaxed">{subhead}</p>
        <div class="mt-4 flex flex-wrap gap-2">
          {trustChips.map((chip) => (
            <span class="inline-flex items-center gap-1.5 rounded-full bg-white/80 border border-teal/20 px-3 py-1.5 text-xs sm:text-sm font-semibold text-teal-dark">
              <svg class="w-3.5 h-3.5 text-teal shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
              </svg>
              {chip}
            </span>
          ))}
        </div>
      </div>

      <!-- B: ajánlatkérő wizard (mobil: 2. – above the fold; desktop: jobb hasáb) -->
      <div class="lg:col-start-2 lg:row-start-1 lg:row-span-2">
        <QuoteWizard formSource={formSource} service={service} anchorId="lp-form" compact />
      </div>

      <!-- C: bullets + garancia-badge (mobil: a wizard alatt) -->
      <div class="lg:col-start-1">
        <ul class="space-y-3">
          {bullets.map((b) => (
            <li class="flex items-start gap-3 text-body text-base lg:text-lg">
              <svg class="w-6 h-6 text-teal shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span set:html={b} />
            </li>
          ))}
        </ul>

        <div class="mt-6 inline-flex items-center gap-3 rounded-xl bg-teal-dark px-5 py-4 text-white">
          <svg class="w-7 h-7 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <div>
            <div class="font-heading font-bold text-lg leading-tight">40 millió Ft bírsággarancia</div>
            <div class="text-white/80 text-sm">0 bírság cégünk fennállása alatt</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- (3) REFERENCIA-LOGÓK – grayscale bizalmi sáv (enterprise-üzenettel) -->
<section class="bg-white py-10 lg:py-14 border-y border-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <p class="text-center text-muted text-sm font-medium uppercase tracking-wide">
      100+ fős vállalatok megbízható partnere – több mint 48 cég bízza ránk a megfelelőségét
    </p>
    <div class="mt-8 grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-6 gap-x-6 gap-y-8 items-center">
      {trustLogos.map((logo) => (
        <div class="flex items-center justify-center h-16">
          <img
            src={logo.img}
            alt={logo.name}
            class="max-h-14 max-w-full object-contain grayscale opacity-70 hover:opacity-100 hover:grayscale-0 transition-all duration-300"
            loading="lazy"
            width="160"
            height="64"
          />
        </div>
      ))}
    </div>
  </div>
</section>

<!-- (4) TESTIMONIAL -->
<section class="bg-surface py-12 lg:py-16">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <svg class="w-10 h-10 text-teal/30 mx-auto" fill="currentColor" viewBox="0 0 24 24">
      <path d="M7.17 6A5.17 5.17 0 002 11.17V18h6.83v-6.83H5.5A1.67 1.67 0 017.17 9.5V6zm9 0A5.17 5.17 0 0011 11.17V18h6.83v-6.83H14.5a1.67 1.67 0 011.67-1.67V6z" />
    </svg>
    <blockquote class="mt-4 font-heading text-xl lg:text-2xl text-heading leading-relaxed">
      „{quote}”
    </blockquote>
    <p class="mt-4 text-muted font-medium">{quoteAuthor}</p>
  </div>
</section>

<!-- (5) AMIT KAP – 4 lépés -->
<section class="bg-white py-12 lg:py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="font-heading font-bold text-2xl lg:text-3xl text-heading text-center">Amit kap tőlünk</h2>
    <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {steps.map((step, i) => (
        <div class="rounded-xl border border-border bg-surface p-6">
          <div class="w-10 h-10 rounded-full bg-teal text-white font-heading font-bold flex items-center justify-center">
            {i + 1}
          </div>
          <h3 class="mt-4 font-heading font-semibold text-heading">{step.title}</h3>
          <p class="mt-2 text-body text-sm leading-relaxed">{step.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- (5b) FELELŐSSÉG-ÁTVÁLLALÁS – "A felelősséget mi visszük" -->
<section class="bg-heading py-12 lg:py-16">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="font-heading font-bold text-2xl lg:text-3xl text-white">
      A felelősséget mi visszük
    </h2>
    <p class="mt-4 text-white/85 text-lg leading-relaxed">
      Egy hatósági ellenőrzésnél vagy munkabalesetnél a vezető személyesen felel.
      Nálunk ez másképp működik: az általunk gondozott területekért
      <strong class="text-white">40 millió Ft-ig anyagi felelősséget vállalunk</strong> –
      írásban, biztosítási fedezettel.
    </p>
    <details class="mt-6 mx-auto max-w-2xl text-left rounded-xl bg-white/5 border border-white/15 open:bg-white/10 transition-colors">
      <summary class="cursor-pointer list-none px-5 py-4 font-heading font-semibold text-white flex items-center justify-between">
        Hogyan működik a bírsággarancia?
        <svg class="w-5 h-5 shrink-0 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </summary>
      <div class="px-5 pb-5 text-white/80 text-sm leading-relaxed space-y-2">
        <p>1. Szerződésben rögzítjük, mely területek tartoznak a gondozásunkba (munkavédelem, tűzvédelem, környezetvédelem).</p>
        <p>2. Ha ezeken a területeken a mi mulasztásunk miatt érné bírság a céget, azt 40 millió Ft-ig megtérítjük – a garancia mögött valódi biztosítási kötvény áll.</p>
        <p>3. Közel 20 év alatt egyetlen partnerünk sem kapott bírságot, így erre még sosem volt szükség.</p>
      </div>
    </details>
  </div>
</section>

<!-- (5c) KIFOGÁSKEZELŐ FAQ -->
<section class="bg-surface py-12 lg:py-16">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="font-heading font-bold text-2xl lg:text-3xl text-heading text-center mb-8">
      Gyakori kérdések
    </h2>
    <FaqAccordion items={faq} />
  </div>
</section>

<!-- (6) WIZARD MEGISMÉTELVE + telefon-CTA -->
<section class="bg-gradient-to-br from-teal-dark to-teal py-14 lg:py-20">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <h2 class="font-heading font-bold text-2xl lg:text-3xl text-white">
        Kérjen ingyenes felmérést még ma
      </h2>
      <p class="mt-3 text-white/85 text-lg">
        Töltse ki az űrlapot, vagy hívjon most – szakértőnk 24 órán belül jelentkezik.
      </p>
      <a
        href={`tel:${PHONE_TEL}`}
        class="mt-6 inline-flex items-center gap-2 px-7 py-3 bg-orange text-white font-heading font-bold text-lg rounded-lg hover:bg-orange-dark transition-colors"
        data-cta="lp-call"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        Hívás most: {PHONE_DISPLAY}
      </a>
      <p class="mt-2 text-white/70 text-sm">Hétfő–péntek 8:00–17:00</p>
    </div>

    <div class="mt-8 scroll-mt-4">
      <QuoteWizard formSource={`${formSource}-bottom`} service={service} anchorId="lp-form-bottom" />
    </div>
  </div>
</section>

<!-- Mobil sticky CTA – itt egyedi (hívás + form-ra ugrás), mert nincs /kapcsolat/ navigáció -->
<div
  class="fixed bottom-0 inset-x-0 z-40 lg:hidden bg-white border-t border-border shadow-[0_-4px_12px_rgba(0,0,0,0.08)]"
  role="region"
  aria-label="Gyors kapcsolat"
>
  <div class="grid grid-cols-2 h-14">
    <a
      href={`tel:${PHONE_TEL}`}
      class="flex items-center justify-center gap-2 font-heading font-semibold text-teal hover:bg-teal-light transition-colors"
      data-cta="lp-mobile-call"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
      </svg>
      <span>Hívás</span>
    </a>
    <a
      href="#lp-form"
      class="flex items-center justify-center gap-2 bg-orange text-white font-heading font-semibold hover:bg-orange-dark transition-colors"
      data-cta="lp-mobile-quote"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
      </svg>
      <span>Ajánlatkérés</span>
    </a>
  </div>
</div>

<style>
  /* Hogy az utolsó szekció ne csússzon a sticky bar alá mobilon */
  @media (max-width: 1023px) {
    body { padding-bottom: 3.5rem; }
  }
  /* details nyíl forgatása nyitáskor */
  details[open] summary svg { transform: rotate(180deg); }
</style>
