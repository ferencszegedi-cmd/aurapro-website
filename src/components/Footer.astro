---
const currentYear = new Date().getFullYear();
---

<footer class="bg-[#919196] text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <!-- Logo + tagline -->
      <div>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 440 120" fill="none" class="h-10 mb-4" role="img" aria-label="Aurapro – safety first">
          <!-- Outer arc - white top -->
          <path d="M60 8 A52 52 0 0 1 108 52" stroke="#ffffff" stroke-width="14" fill="none"/>
          <!-- Outer arc - orange segment -->
          <path d="M60 8 A52 52 0 0 0 8 60" stroke="#f5a623" stroke-width="14" fill="none"/>
          <!-- Outer arc - white bottom -->
          <path d="M8 60 A52 52 0 0 0 52 108" stroke="#ffffff" stroke-width="14" fill="none"/>
          <!-- Inner circle of 'a' -->
          <circle cx="68" cy="64" r="20" stroke="#ffffff" stroke-width="7" fill="none"/>
          <text x="102" y="82" fill="#ffffff" font-family="Montserrat, sans-serif" font-size="48" font-weight="400">ura</text>
          <text x="218" y="82" fill="#f5a623" font-family="Montserrat, sans-serif" font-size="48" font-weight="600">pro</text>
          <text x="190" y="108" fill="rgba(255,255,255,0.7)" font-family="Montserrat, sans-serif" font-size="17" font-weight="400">safety first</text>
        </svg>
        <p class="text-white/70 text-sm leading-relaxed">
          Munkavédelem, tűzvédelem és környezetvédelem – egy kézből, 20 millió Ft bírsággaranciával.
        </p>
      </div>

      <!-- Szolgáltatások -->
      <div>
        <h3 class="font-heading font-semibold text-sm uppercase tracking-wide mb-4">Szolgáltatások</h3>
        <ul class="space-y-2">
          <li><a href="/munkavedelem/" class="text-white/70 hover:text-white transition-colors text-sm">Munkavédelem</a></li>
          <li><a href="/tuzvedelem/" class="text-white/70 hover:text-white transition-colors text-sm">Tűzvédelem</a></li>
          <li><a href="/kornyezetvedelem/" class="text-white/70 hover:text-white transition-colors text-sm">Környezetvédelem</a></li>
        </ul>
      </div>

      <!-- Cég -->
      <div>
        <h3 class="font-heading font-semibold text-sm uppercase tracking-wide mb-4">Cég</h3>
        <ul class="space-y-2">
          <li><a href="/rolunk/" class="text-white/70 hover:text-white transition-colors text-sm">Rólunk</a></li>
          <li><a href="/referenciak/" class="text-white/70 hover:text-white transition-colors text-sm">Referenciák</a></li>
          <li><a href="/munkatarsaink/" class="text-white/70 hover:text-white transition-colors text-sm">Munkatársaink</a></li>
          <li><a href="/gyik/" class="text-white/70 hover:text-white transition-colors text-sm">GYIK</a></li>
          <li><a href="/adatvedelem/" class="text-white/70 hover:text-white transition-colors text-sm">Adatvédelem</a></li>
          <li><a href="/impresszum/" class="text-white/70 hover:text-white transition-colors text-sm">Impresszum</a></li>
        </ul>
      </div>

      <!-- Kapcsolat -->
      <div>
        <h3 class="font-heading font-semibold text-sm uppercase tracking-wide mb-4">Kapcsolat</h3>
        <ul class="space-y-2 text-sm text-white/70">
          <li>
            <a href="tel:+36704098764" class="hover:text-white transition-colors">+36 70 409 8764</a>
          </li>
          <li>
            <a href="mailto:info@aurapro.hu" class="hover:text-white transition-colors">info@aurapro.hu</a>
          </li>
          <li>2040 Budaörs, Gyár utca 2.</li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-white/20 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-white/50">
        &copy; {currentYear} Aurapro Kft. Minden jog fenntartva.
      </p>
    </div>
  </div>
</footer>
