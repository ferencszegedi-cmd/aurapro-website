---
// P1-2: Mobile sticky CTA bar – Lovable spec
// Csak < lg breakpoint alatt látszik. A /kapcsolat/ és /koszonjuk/ oldalakon elrejtjük (a gtag esemény adatkörén szerepelhet, de UX okból ne ismétlődjön).
const path = Astro.url.pathname;
const hideOnPaths = ['/kapcsolat/', '/kapcsolat', '/koszonjuk/', '/koszonjuk'];
const hidden = hideOnPaths.some((p) => path === p || path.startsWith(p + '/'));
---

{!hidden && (
  <div
    id="mobile-sticky-bar"
    class="fixed bottom-0 inset-x-0 z-40 lg:hidden bg-white border-t border-border shadow-[0_-4px_12px_rgba(0,0,0,0.08)]"
    role="region"
    aria-label="Gyors kapcsolat"
  >
    <div class="grid grid-cols-2 h-14">
      <a
        href="tel:+36704098764"
        class="flex items-center justify-center gap-2 font-heading font-semibold text-teal hover:bg-teal-light transition-colors"
        data-cta="mobile-sticky-call"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        <span>Hívás</span>
      </a>
      <a
        href="/kapcsolat/"
        class="flex items-center justify-center gap-2 bg-orange text-white font-heading font-semibold hover:bg-orange-dark transition-colors"
        data-cta="mobile-sticky-quote"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        <span>Ajánlatkérés</span>
      </a>
    </div>
  </div>
)}

<style>
  /* Hogy az utolsó szekció ne csússzon a sticky bar alá mobilon */
  @media (max-width: 1023px) {
    body { padding-bottom: 3.5rem; }
  }
</style>
