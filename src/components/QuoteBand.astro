---
/**
 * CTA-sáv a QuoteWizard-dal – a régi <ContactForm inline /> utódja.
 * Oldal-aljakra való: színes sáv + középre igazított wizard-kártya.
 */
import QuoteWizard from './QuoteWizard.astro';
import type { ServiceValue } from '../lib/lead-types';
import { ui, type Lang } from '../i18n/ui';

interface Props {
  /** data-form forrás-azonosító (analytics) – oldalanként egyedi legyen! */
  formSource: string;
  /** Előre bepipált szolgáltatások a wizard 1. lépésén. */
  services?: ServiceValue[];
  /** Sáv-címsor felülírása. */
  title?: string;
  /** Sáv-alcím felülírása. */
  subtitle?: string;
  /** Opcionális szekció-id (pl. hero CTA #ajanlat horgonyához). */
  anchorId?: string;
  lang?: Lang;
}

const { lang = 'hu' } = Astro.props;
const b = ui[lang].band;
const {
  formSource,
  services,
  title = b.title,
  subtitle = b.subtitle,
  anchorId,
} = Astro.props;
const badges = [b.badgeFree, b.badge24h, b.badgeGuarantee];
---

<section id={anchorId} class="py-12 lg:py-16 bg-orange scroll-mt-4">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="font-heading font-bold text-2xl lg:text-3xl text-white">{title}</h2>
    <p class="mt-2 text-white/80 text-lg">{subtitle}</p>

    <div class="mt-8 max-w-2xl mx-auto">
      <QuoteWizard formSource={formSource} services={services} showHeader={false} lang={lang} />
    </div>

    <div class="mt-6 flex flex-wrap items-center justify-center gap-2.5">
      {badges.map((item) => (
        <span class="inline-flex items-center gap-2 rounded-full bg-white/15 border border-white/30 px-4 py-2 text-white font-semibold text-sm lg:text-base">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
          </svg>
          {item}
        </span>
      ))}
    </div>
  </div>
</section>
