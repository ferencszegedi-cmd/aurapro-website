---
import { ui, type Lang } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  href: string;
  icon: 'shield' | 'fire' | 'leaf';
  lang?: Lang;
}

const { title, description, href, icon, lang = 'hu' } = Astro.props;
const detailsLabel = ui[lang].card.details;

const icons = {
  shield: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>`,
  fire: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z"/>`,
  leaf: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>`,
};
---

<a href={href} class="group block bg-white rounded-xl border border-border p-8 hover:shadow-lg hover:border-teal/30 transition-all" data-animate>
  <div class="w-12 h-12 rounded-lg bg-teal-light flex items-center justify-center mb-5">
    <svg class="w-6 h-6 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={icons[icon]} />
  </div>
  <h3 class="font-heading font-semibold text-xl text-heading group-hover:text-teal transition-colors">{title}</h3>
  <p class="mt-3 text-body text-sm leading-relaxed">{description}</p>
  <span class="mt-4 inline-flex items-center text-teal font-medium text-sm group-hover:gap-2 transition-all">
    {detailsLabel}
    <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
  </span>
</a>
