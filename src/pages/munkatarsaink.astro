---

<PageLayout
  title="Munkatársaink – Aurapro | 30 szakértő országszerte"
  description="Ismerje meg az Aurapro csapatát: 30 szakértő munkavédelmi, tűzvédelmi és környezetvédelmi szakemberek, mérnökök és koordinátorok."
  canonical="/munkatarsaink/"
>
  <!-- Page hero -->
  <section class="py-16 lg:py-24 bg-gradient-to-br from-teal-light to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="font-heading font-bold text-4xl lg:text-5xl text-heading">Munkatársaink</h1>
        <p class="mt-4 text-lg text-body leading-relaxed">
          30 szakértő, mérnökök, technikusok és koordinátorok – országszerte biztosítjuk partnereink biztonságát.
        </p>
      </div>
    </div>
  </section>

  <!-- Leadership -->
  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading font-bold text-3xl text-heading text-center mb-12">Vezetőség és iroda</h2>
      <div class="flex flex-wrap justify-center gap-6 lg:gap-8 max-w-5xl mx-auto">
        {leadership.map((person) => (
          <div class="text-center group basis-[42%] sm:basis-[28%] lg:basis-[21%]" data-animate>
            <div class="relative w-36 h-36 mx-auto mb-4 rounded-full overflow-hidden bg-surface border-2 border-border shadow-md transition-shadow duration-300 group-hover:shadow-lg group-hover:border-teal">
              <img
                src={person.img}
                alt={person.name}
                class="w-full h-full object-cover object-top grayscale transition-all duration-500 group-hover:grayscale-0 group-hover:scale-105"
                loading="lazy"
              />
            </div>
            <h3 class="font-heading font-semibold text-heading">{person.name}</h3>
            <p class="text-teal text-sm font-medium mt-1">{person.role}</p>
            {person.desc && <p class="text-muted text-xs mt-1">{person.desc}</p>}
            <div class="mt-2 space-y-1">
              {person.phone && (
                <a href={`tel:${person.phone}`} class="flex items-center justify-center gap-1.5 text-muted hover:text-teal transition-colors text-xs">
                  <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                  {person.phone}
                </a>
              )}
              {person.email && (
                <a href={`mailto:${person.email}`} class="flex items-center justify-center gap-1.5 text-muted hover:text-teal transition-colors text-xs">
                  <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                  {person.email}
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Specialists -->
  <section class="py-16 lg:py-20 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading font-bold text-3xl text-heading text-center mb-12">Szakértőink</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-4 gap-6 lg:gap-8">
        {specialists.map((person) => (
          <div class="text-center group" data-animate>
            <div class="relative w-28 h-28 mx-auto mb-3 rounded-full overflow-hidden bg-white border-2 border-border shadow-md transition-shadow duration-300 group-hover:shadow-lg group-hover:border-teal">
              <img
                src={person.img}
                alt={person.name}
                class="w-full h-full object-cover object-top grayscale transition-all duration-500 group-hover:grayscale-0 group-hover:scale-105"
                loading="lazy"
              />
            </div>
            <h3 class="font-heading font-semibold text-sm text-heading">{person.name}</h3>
            <p class="text-teal text-xs font-medium mt-1">{person.role}</p>
            {person.desc && <p class="text-muted text-xs mt-0.5">{person.desc}</p>}
            <div class="mt-1.5 space-y-0.5">
              {person.phone && (
                <a href={`tel:${person.phone}`} class="flex items-center justify-center gap-1 text-muted hover:text-teal transition-colors text-[11px]">
                  <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                  {person.phone}
                </a>
              )}
              {person.email && (
                <a href={`mailto:${person.email}`} class="flex items-center justify-center gap-1 text-muted hover:text-teal transition-colors text-[11px]">
                  <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                  {person.email}
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats band -->
  <section class="py-12 lg:py-16 bg-teal-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 text-center">
        <div>
          <div class="font-heading font-bold text-4xl text-white">21</div>
          <div class="mt-1 text-white/70 text-sm">szakértő</div>
        </div>
        <div>
          <div class="font-heading font-bold text-4xl text-white">13+</div>
          <div class="mt-1 text-white/70 text-sm">év tapasztalat</div>
        </div>
        <div>
          <div class="font-heading font-bold text-4xl text-white">48+</div>
          <div class="mt-1 text-white/70 text-sm">nagyvállalati referencia</div>
        </div>
        <div>
          <div class="font-heading font-bold text-4xl text-white">0</div>
          <div class="mt-1 text-white/70 text-sm">bírság eddig</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <QuoteBand formSource="band-munkatarsaink" />
</PageLayout>
