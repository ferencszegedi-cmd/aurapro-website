---
import PageLayout from '../layouts/PageLayout.astro';

// Build-időben kiolvasott env vars (define:vars-szal továbbadva az inline scriptnek)
const ADS_ID = import.meta.env.PUBLIC_ADS_CONVERSION_ID ?? '';
const ADS_LEAD_LABEL = import.meta.env.PUBLIC_ADS_LEAD_LABEL ?? '';
---

<PageLayout
  title="Köszönjük az ajánlatkérést! – Aurapro"
  description="Megkaptuk az ajánlatkérését. 24 órán belül visszahívjuk a megadott telefonszámon."
  canonical="/koszonjuk/"
  noIndex={true}
>
  <!-- P0-2: GA4 lead conversion fire – csak ha a gtag betöltődött (és a felhasználó elfogadta a sütiket) -->
  <script slot="head" is:inline define:vars={{ ADS_ID, ADS_LEAD_LABEL }}>
    (function () {
      if (typeof window === 'undefined') return;
      // A submit-oldali script sessionStorage-ba teszi a form_id/service párost,
      // így a konverzió LP-nként attribútálható GA4-ben (per-LP CPL).
      var attribution = {};
      try {
        attribution = JSON.parse(sessionStorage.getItem('aurapro_lead') || '{}');
        sessionStorage.removeItem('aurapro_lead');
      } catch (e) { /* ignored */ }
      function fireConversion() {
        if (typeof window.gtag !== 'function') return;
        window.gtag('event', 'generate_lead', {
          value: 1,
          currency: 'HUF',
          form_id: attribution.form_id || undefined,
          service: attribution.service || undefined,
        });
        // Google Ads conversion (csak ha PUBLIC_ADS_CONVERSION_ID + PUBLIC_ADS_LEAD_LABEL env-ben van)
        if (ADS_ID && ADS_LEAD_LABEL) {
          window.gtag('event', 'conversion', {
            send_to: ADS_ID + '/' + ADS_LEAD_LABEL,
            value: 1,
            currency: 'HUF',
          });
        }
      }
      // Próbálkozás 200ms-onként, max 2s (a gtag.js async tölt)
      var attempts = 0;
      var iv = setInterval(function () {
        attempts++;
        if (typeof window.gtag === 'function' || attempts > 10) {
          clearInterval(iv);
          fireConversion();
        }
      }, 200);
    })();
  </script>

  <section class="min-h-[60vh] flex items-center py-20 lg:py-28 bg-gradient-to-br from-teal-light via-white to-orange-light/30">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="mx-auto w-20 h-20 rounded-full bg-teal/10 flex items-center justify-center">
        <svg class="w-10 h-10 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
        </svg>
      </div>
      <h1 class="mt-6 font-heading font-bold text-3xl lg:text-5xl text-heading">
        Köszönjük az ajánlatkérést!
      </h1>
      <p class="mt-4 text-lg lg:text-xl text-body leading-relaxed">
        Megkaptuk az adatait. Egy Aurapro szakértő <strong>24 órán belül</strong> visszahívja
        a megadott telefonszámon, és személyre szabott ajánlatot küldünk.
      </p>

      <div class="mt-10 rounded-xl bg-white border border-border p-6 lg:p-8 shadow-sm">
        <h2 class="font-heading font-semibold text-xl text-heading">Sürgős? Hívjon közvetlenül:</h2>
        <a href="tel:+36704098764"
          class="mt-4 inline-flex items-center gap-3 text-2xl lg:text-3xl font-heading font-bold text-orange hover:text-orange-dark transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          +36 70 409 8764
        </a>
        <p class="mt-2 text-sm text-muted">H–P 8:00–17:00</p>
      </div>

      <div class="mt-10 flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="inline-flex items-center justify-center px-6 py-3 text-teal font-heading font-semibold hover:text-teal-dark transition-colors">
          ← Vissza a főoldalra
        </a>
        <a href="/birsaggarancia/" class="inline-flex items-center justify-center px-6 py-3 border-2 border-orange text-orange-dark font-heading font-semibold rounded-lg hover:bg-orange-light transition-colors">
          Tudjon meg többet a 40M Ft bírsággaranciáról →
        </a>
      </div>
    </div>
  </section>
</PageLayout>
