---
import { Image } from 'astro:assets';
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import StatCounter from '../components/StatCounter.astro';
import ServiceCard from '../components/ServiceCard.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import QuoteBand from '../components/QuoteBand.astro';
import LiteYouTube from '../components/LiteYouTube.astro';
import heroSafety from '../assets/images/hero-safety.jpg';
import ytOktatas from '../assets/images/yt-oktatas.jpg';
import ytAdatbazis from '../assets/images/yt-adatbazis.jpg';
import serviceMv from '../assets/images/service-munkavedelem.jpg';
import serviceTv from '../assets/images/service-tuzvedelem.jpg';
import serviceKv from '../assets/images/service-kornyezetvedelem.jpg';
import serviceOktatas from '../assets/images/service-oktatas.jpg';
import iparagak from '../assets/images/iparagak.jpg';

const faqItems = [
  {
    question: 'Mennyibe kerül a munkavédelem?',
    answer: 'Az ár a cég méretétől, tevékenységétől és telephelyeinek számától függ. Kérjen ingyenes felmérést, és 24 órán belül személyre szabott ajánlatot küldünk – kötelezettségmentesen.',
  },
  {
    question: 'Milyen gyakran kell munkavédelmi oktatást tartani?',
    answer: 'A munkavédelmi oktatást jellemzően évente ismétlik az ismeretek fenntartása érdekében; soron kívül pedig munkakör-változáskor, új technológia bevezetésekor vagy munkabaleset után.',
  },
  {
    question: 'Mekkora bírságot kaphat munkavédelmi hiányosságért?',
    answer: 'A munkavédelmi bírság összege jelentős lehet – kis- és középvállalkozásnál akár 25–50 millió forint (25/2024. Korm. r.). Éppen ezért vállalunk 40 millió Ft bírsággaranciát – ügyfeleink biztonságban vannak.',
  },
  {
    question: 'Mikor kötelező a tűzvédelmi szabályzat?',
    answer: 'Tűzvédelmi szabályzatot kell készíteni, ha a cég ötvennél több munkavállalót foglalkoztat, 50 főnél nagyobb befogadóképességű helyiséget vagy 10 fő feletti kereskedelmi szálláshelyet üzemeltet (1996. évi XXXI. tv. 19. §).',
  },
];

// P0-4: FAQ JSON-LD a homepage FAQ blokkhoz
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
---

<PageLayout
  title="Aurapro – Munkavédelem és tűzvédelem 40M Ft bírsággaranciával"
  description="Munkavédelem, tűzvédelem, környezetvédelem egy kézből. 30 szakértő, 48+ nagyvállalati referencia, közel 20 év tapasztalat. Kérjen ingyenes ajánlatot 24 órán belül!"
  canonical="/"
>
  <!-- P0-4: FAQ JSON-LD (a ProfessionalService schema a BaseLayout-ban van) -->
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)} />

  <!-- Hero -->
  <Hero
    title="Munkavédelem, tűzvédelem, környezetvédelem – egy kézből"
    subtitle="Teljes körű szolgáltatás 100 fő feletti cégeknek – 40 millió Ft bírsággaranciával."
    ctaText="Ingyenes ajánlat 24 órán belül"
    ctaHref="#ajanlat"
    secondaryCtaText="+36 70 409 8764"
    secondaryCtaSubtext="Hétfő–péntek 8:00–17:00"
    heroImage={heroSafety}
    heroImageAlt="Munkavédelmi szakértő és üzemvezető modern gyártócsarnokban"
  />

  <!-- Social proof numbers -->
  <StatCounter />

  <!-- Referencia-logófal: a legerősebb bizalmi elem közvetlenül a hajtás után -->
  <section class="py-12 lg:py-16 bg-white border-b border-border">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-center font-heading font-bold text-3xl lg:text-4xl text-heading">Akik már minket választottak</h2>
      <p class="mt-3 mb-12 text-center text-body text-base lg:text-lg font-semibold uppercase tracking-[0.15em]">100+ fős vállalatok megbízható partnere</p>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-8 lg:gap-12 items-center justify-items-center grayscale hover:grayscale-0 transition-all duration-500">
        <a href="/referenciak/#epitoipar-kivitelezes"><img src="/referenciak/audi.jpg" alt="Audi" class="h-24 object-contain" loading="lazy" /></a>
        <a href="/referenciak/#gyartas-ipar"><img src="/referenciak/siemens.jpg" alt="Siemens" class="h-24 object-contain" loading="lazy" /></a>
        <a href="/referenciak/#epitoipar-kivitelezes"><img src="/referenciak/richter.jpg" alt="Richter Gedeon" class="h-24 object-contain" loading="lazy" /></a>
        <a href="/referenciak/#kereskedelem-szolgaltatas"><img src="/referenciak/dm.jpg" alt="DM" class="h-24 object-contain" loading="lazy" /></a>
        <a href="/referenciak/#kereskedelem-szolgaltatas"><img src="/referenciak/primark.jpg" alt="Primark" class="h-24 object-contain" loading="lazy" /></a>
        <a href="/referenciak/#szolgaltatas-kozszfera"><img src="/referenciak/porsche.jpg" alt="Porsche" class="h-24 object-contain" loading="lazy" /></a>
        <a href="/referenciak/#epitoipar-kivitelezes"><img src="/referenciak/egis.jpg" alt="Egis" class="h-24 object-contain" loading="lazy" /></a>
        <a href="/referenciak/#szolgaltatas-kozszfera"><img src="/referenciak/bnp.jpg" alt="BNP Paribas" class="h-24 object-contain" loading="lazy" /></a>
        <a href="/referenciak/#kereskedelem-szolgaltatas"><img src="/referenciak/libri.jpg" alt="Libri" class="h-24 object-contain" loading="lazy" /></a>
        <a href="/referenciak/#szolgaltatas-kozszfera"><img src="/referenciak/adecco.jpg" alt="Adecco" class="h-24 object-contain" loading="lazy" /></a>
        <a href="/referenciak/#kereskedelem-szolgaltatas"><img src="/referenciak/pepco.jpg" alt="Pepco" class="h-24 object-contain" loading="lazy" /></a>
        <a href="/referenciak/#szolgaltatas-kozszfera"><img src="/referenciak/budapest-kozut.jpg" alt="Budapest Közút" class="h-24 object-contain" loading="lazy" /></a>
      </div>
      <div class="mt-10 text-center">
        <a href="/referenciak/" class="inline-flex items-center gap-2 px-7 py-3.5 border-2 border-teal text-teal font-heading font-bold text-xl rounded-lg hover:bg-teal hover:text-white transition-colors">
          +36 másik cég
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-16 lg:py-20 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="font-heading font-bold text-3xl lg:text-4xl text-heading">Szolgáltatásaink</h2>
        <p class="mt-3 text-muted text-lg">Komplex megoldás – egy partner a teljes MV+TV+KV-ra</p>
      </div>
      <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
        <a href="/munkavedelem/" class="group block bg-white rounded-xl border border-border overflow-hidden hover:shadow-lg hover:border-teal/30 transition-all" data-animate>
          <div class="h-40 overflow-hidden">
            <Image src={serviceMv} alt="Munkavédelmi szakértő gépátvizsgálás közben" widths={[480, 800]} sizes="(min-width: 768px) 33vw, 100vw" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-6">
            <h3 class="font-heading font-semibold text-xl text-heading group-hover:text-teal transition-colors">Munkavédelem</h3>
            <p class="mt-3 text-body text-sm leading-relaxed">Kockázatértékelés, munkavédelmi oktatás, koordinátor, szabályzatok, hatósági ügyintézés.</p>
            <span class="mt-4 inline-flex items-center text-teal font-medium text-sm">Részletek <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg></span>
          </div>
        </a>
        <a href="/tuzvedelem/" class="group block bg-white rounded-xl border border-border overflow-hidden hover:shadow-lg hover:border-teal/30 transition-all" data-animate>
          <div class="h-40 overflow-hidden">
            <Image src={serviceTv} alt="Tűzvédelmi szakember tűzoltókészülék-ellenőrzés közben" widths={[480, 800]} sizes="(min-width: 768px) 33vw, 100vw" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-6">
            <h3 class="font-heading font-semibold text-xl text-heading group-hover:text-teal transition-colors">Tűzvédelem</h3>
            <p class="mt-3 text-body text-sm leading-relaxed">Tűzvédelmi szabályzat, tűzriadó terv, felülvizsgálatok, oktatás, tervezés és engedélyeztetés.</p>
            <span class="mt-4 inline-flex items-center text-teal font-medium text-sm">Részletek <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg></span>
          </div>
        </a>
        <a href="/kornyezetvedelem/" class="group block bg-white rounded-xl border border-border overflow-hidden hover:shadow-lg hover:border-teal/30 transition-all" data-animate>
          <div class="h-40 overflow-hidden">
            <Image src={serviceKv} alt="Környezetvédelmi mérnök mintavétel közben" widths={[480, 800]} sizes="(min-width: 768px) 33vw, 100vw" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-6">
            <h3 class="font-heading font-semibold text-xl text-heading group-hover:text-teal transition-colors">Környezetvédelem</h3>
            <p class="mt-3 text-body text-sm leading-relaxed">Hulladékgazdálkodás, környezetvédelmi engedélyek, zajmérés, levegőtisztaság-védelem.</p>
            <span class="mt-4 inline-flex items-center text-teal font-medium text-sm">Részletek <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg></span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Saját fejlesztésű szolgáltatások - videók -->
  <section id="online-oktatas" class="pt-4 pb-10 lg:pt-6 lg:pb-12 bg-white scroll-mt-24">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading font-bold text-3xl lg:text-4xl text-heading text-center mb-8">Saját fejlesztésű szolgáltatásaink</h2>
      <div class="grid md:grid-cols-2 gap-6 lg:gap-8">
        <div>
          <h3 class="font-heading font-semibold text-lg text-heading text-center mb-3">Online oktatási oldal</h3>
          <LiteYouTube videoId="5_KcdPdQ2gY" title="Online oktatási oldal bemutató" thumb={ytOktatas} />
          <p class="mt-3 text-center">
            <a href="https://www.auraoktatas.hu/" target="_blank" rel="noopener" class="inline-flex items-center text-teal font-medium text-sm hover:text-teal-dark transition-colors">
              auraoktatas.hu megnyitása
              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </p>
        </div>
        <div>
          <h3 class="font-heading font-semibold text-lg text-heading text-center mb-3">Online adatbázis</h3>
          <LiteYouTube videoId="uHyexWO8GSc" title="Online adatbázis bemutató" thumb={ytAdatbazis} />
        </div>
      </div>
      <h2 class="font-heading font-bold text-3xl lg:text-4xl text-heading text-center mt-20 mb-8">Munkavédelmi képviselő képzés és Elsősegélynyújtó tanfolyam</h2>
      <div class="grid md:grid-cols-2 gap-6 lg:gap-8">
        <a href="/munkavedelmi-kepviselo-kepzes/" class="group block bg-white rounded-xl border border-border overflow-hidden hover:shadow-lg hover:border-teal/30 transition-all">
          <div class="h-48 overflow-hidden">
            <Image src={serviceOktatas} alt="Munkavédelmi képviselő képzés tréningteremben" widths={[480, 800]} sizes="(min-width: 768px) 50vw, 100vw" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-6">
            <h3 class="font-heading font-semibold text-xl text-heading group-hover:text-teal transition-colors">Munkavédelmi képviselő képzés</h3>
            <p class="mt-3 text-body text-sm leading-relaxed">Cégünk gyorsan és rugalmasan segít Önnek az alapképzés elvégzésében! Több éves oktatói és napi szintű gyakorlati tapasztalattal rendelkező szakembereink készítik fel a munkavédelmi képviselőket.</p>
            <span class="mt-4 inline-flex items-center text-teal font-medium text-sm">További információk <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg></span>
          </div>
        </a>
        <a href="/elsosegelynyujto-tanfolyam/" class="group block bg-white rounded-xl border border-border overflow-hidden hover:shadow-lg hover:border-teal/30 transition-all">
          <div class="h-48 overflow-hidden">
            <img src="/images/elsosegelynyujto.jpg" alt="Munkahelyi elsősegélynyújtó tanfolyam" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-6">
            <h3 class="font-heading font-semibold text-xl text-heading group-hover:text-teal transition-colors">Munkahelyi elsősegélynyújtó tanfolyam</h3>
            <p class="mt-3 text-body text-sm leading-relaxed">Készítse fel cégét a jogszabályi előírásoknak megfelelően – minden műszakban kell lennie képzett elsősegélynyújtó személynek. Intenzív 4 órás, gyakorlatorientált képzés.</p>
            <span class="mt-4 inline-flex items-center text-teal font-medium text-sm">További információk <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg></span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Why Aurapro -->
  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="font-heading font-bold text-3xl lg:text-4xl text-heading">Miért minket választanak ügyfeleink?</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-6 lg:gap-8 max-w-4xl mx-auto">
        {[
          { title: '40 millió Ft bírsággarancia', desc: 'Egyedülálló a piacon – vállaljuk a felelősséget a munkánkért.', link: '/birsaggarancia/', linkLabel: 'Részletek' },
          { title: '48+ nagyvállalati referencia', desc: 'Audi, Siemens, Richter, DM, Primark – és még sokan mások.' },
          { title: '1 partnerünk sem kapott bírságot', desc: 'Bizonyított eredmény, nem csak ígéret.' },
          { title: 'Komplex szolgáltatás egy kézből', desc: 'MV + TV + KV – kevesebb koordináció, több hatékonyság.' },
          { title: '30 szakértő országszerte', desc: 'Nem egyemberes vállalkozás – bármikor elérhető kapacitás.' },
          { title: 'közel 20 év tapasztalat', desc: 'Stabil háttér, kipróbált módszertannal.' },
        ].map((item) => (
          <div class="flex gap-4">
            <div class="shrink-0 w-10 h-10 rounded-full bg-teal-light flex items-center justify-center">
              <svg class="w-5 h-5 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <div>
              <h3 class="font-heading font-semibold text-heading">{item.title}</h3>
              <p class="mt-1 text-body text-sm">{item.desc}</p>
              {item.link && (
                <a href={item.link} class="mt-1 inline-flex items-center text-teal text-sm font-medium hover:text-teal-dark transition-colors">
                  {item.linkLabel ?? 'Részletek'}
                  <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
      <div class="mt-12 text-center">
        <a href="/kapcsolat/" class="inline-flex items-center px-8 py-4 bg-orange text-white font-heading font-bold rounded-lg hover:bg-orange-dark transition-colors">
          Kérjen ingyenes ajánlatot
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Vélemények rólunk -->
  <section class="py-16 lg:py-20 bg-[#919196]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-center font-heading font-bold text-3xl lg:text-4xl text-white mb-12">Vélemények rólunk</h2>
      <div class="grid md:grid-cols-2 gap-6 lg:gap-8 max-w-5xl mx-auto">
        {[
          {
            quote: 'Az egyedi igényeinkre szabott megoldások és a rugalmas hozzáállás tette igazán értékessé számunkra ezt az együttműködést. A munkavállalóink is pozitívan fogadták a változásokat.',
            name: 'Nagy Eszter',
            title: 'HR vezető',
          },
          {
            quote: 'A bevezetett intézkedések nemcsak a biztonságot növelték, de pozitív hatással voltak a munkahelyi légkörre és a termelékenységre is. Win-win szituációt teremtettek.',
            name: 'Tóth Mária',
            title: 'Üzletág vezető',
          },
          {
            quote: 'Lenyűgöző volt számunkra a cég gyorsasága és precizitása. Amikor sürgős munkavédelmi audit vált szükségessé egyik új üzletünkben, rekordidő alatt, mégis minden részletre kiterjedően végezték el a felmérést. Ez a fajta hatékonyság kulcsfontosságú volt számunkra a határidők betartásában, miközben egy pillanatig sem kellett aggódnunk a minőség miatt.',
            name: 'Fehér Gábor',
            title: 'Expanziós igazgató',
          },
          {
            quote: 'A munkatársaimtól kapott visszajelzések alapján az oktatások valóban újszerűek és rendkívül érthetőek voltak. Külön kiemelték, hogy a hagyományosan száraz munkavédelmi tananyagot hogyan sikerült a trénereknek életszerű példákkal és interaktív gyakorlatokkal színesíteniük. Ez nem csak az információk jobb megértését és megjegyzését segítette elő, de a munkavállalók hozzáállását is pozitívan befolyásolta a munkavédelem fontosságával kapcsolatban.',
            name: 'Dr. Németh Katalin',
            title: 'Humánerőforrás igazgató',
          },
        ].map((item) => (
          <div class="bg-white/10 rounded-xl p-6 lg:p-8">
            <svg class="w-8 h-8 text-orange mb-4" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zm-14.017 0v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H0z"/></svg>
            <p class="text-white/90 text-sm leading-relaxed italic mb-4">{item.quote}</p>
            <div>
              <p class="font-heading font-semibold text-orange">{item.name}</p>
              <p class="text-white/60 text-sm">{item.title}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Bírsággarancia -->
  <section class="pt-4 pb-16 lg:pt-6 lg:pb-20 bg-white relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="font-heading font-bold text-3xl lg:text-4xl text-heading">40 millió Ft bírsággarancia</h2>
          <p class="mt-4 text-body text-lg leading-relaxed">
            Annyira bízunk a munkánkban, hogy egyedülálló garanciát vállalunk: ha partnerünket bírság éri a mi mulasztásunk miatt,
            a bírság összegét megtérítjük – <strong>40 millió Ft-ig</strong>.
          </p>
          <p class="mt-3 text-body leading-relaxed">
            Ez nem csupán ígéret – szakmai felelősségbiztosításunk fedezi. Egyetlen partnerünk sem kapott bírságot közel 20 év alatt.
          </p>
          <div class="mt-6 flex flex-col sm:flex-row gap-3">
            <a href="/birsaggarancia/" class="inline-flex items-center px-6 py-3 bg-orange text-white font-heading font-semibold rounded-lg hover:bg-orange-dark transition-colors">
              Hogyan működik a garancia?
              <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <a href="/biztositasi-garancia.pdf" target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-6 py-3 border-2 border-orange text-orange-dark font-heading font-semibold rounded-lg hover:bg-orange-light transition-colors">
              Kötvény (PDF)
            </a>
          </div>
        </div>
        <div class="hidden lg:block">
          <img src="/images/bgr-orange.png" alt="Bírsággarancia" class="rounded-2xl shadow-lg" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Industry segments -->
  <section class="py-16 lg:py-20 bg-[#919196]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="font-heading font-bold text-3xl lg:text-4xl text-white mb-6">Minden iparágban otthon vagyunk</h2>
          <p class="text-white/80 text-lg mb-8">Építőipartól a kereskedelemig, gyártástól az irodákig – közel 20 év tapasztalat minden szektorban.</p>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
            {[
              { label: 'Építőipar', href: '/referenciak/#epitoipar-kivitelezes', icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2 20h20M6 20V10l6-6 6 6v10M9 20v-4a3 3 0 016 0v4"/>' },
              { label: 'Gyártás', href: '/referenciak/#gyartas-ipar', icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><circle cx="12" cy="12" r="3" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>' },
              { label: 'Kereskedelem', href: '/referenciak/#kereskedelem-szolgaltatas', icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/>' },
              { label: 'Irodák', href: '/referenciak/#szolgaltatas-kozszfera', icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0H5m14 0h2m-16 0H3m5-12h.01M8 13h.01M12 9h.01M12 13h.01M16 9h.01M16 13h.01"/>' },
              { label: 'Raktárak', href: '/referenciak/#gyartas-ipar', icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>' },
              { label: 'Közszféra', href: '/referenciak/#szolgaltatas-kozszfera', icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>' },
            ].map((item) => (
              <a href={item.href} class="bg-white/10 rounded-xl p-4 text-center hover:bg-white/20 transition-colors flex flex-col items-center gap-2">
                <svg class="w-8 h-8 text-white/80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><Fragment set:html={item.icon} /></svg>
                <span class="font-heading font-semibold text-white text-sm">{item.label}</span>
              </a>
            ))}
          </div>
          <a href="/referenciak/" class="mt-8 inline-flex items-center gap-2 px-7 py-3.5 bg-orange text-white font-heading font-bold text-lg rounded-lg hover:bg-orange-dark transition-colors shadow-lg">
            Összes referencia megtekintése <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
        <div class="hidden lg:block">
          <Image src={iparagak} alt="Modern ipari park: gyártócsarnok, logisztikai raktár, irodaház és építkezés toronydaruval" widths={[640, 1024, 1600]} sizes="(min-width: 1024px) 50vw, 100vw" class="rounded-2xl shadow-lg" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ preview -->
  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="font-heading font-bold text-3xl lg:text-4xl text-heading">Gyakran ismételt kérdések</h2>
      </div>
      <div class="max-w-3xl mx-auto">
        <FaqAccordion items={faqItems} />
        <div class="mt-8 text-center">
          <a href="/gyik/" class="inline-flex items-center gap-2 px-7 py-3.5 border-2 border-teal text-teal font-heading font-bold text-lg rounded-lg hover:bg-teal hover:text-white transition-colors">
            Összes kérdés megtekintése
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA band -->
  <QuoteBand formSource="home-band" anchorId="ajanlat" />

</PageLayout>
