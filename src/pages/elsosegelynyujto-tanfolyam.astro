---
import PageLayout from '../layouts/PageLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<PageLayout
  title="Munkahelyi elsősegélynyújtó tanfolyam – Aurapro"
  description="Intenzív 4 órás, gyakorlatorientált elsősegélynyújtó képzés AMBU-Man gyakorlóbabával és defibrillátor-használattal. 24.900 Ft + ÁFA/fő."
  canonical="/elsosegelynyujto-tanfolyam/"
>
  <section class="py-16 lg:py-24 bg-gradient-to-br from-teal-light to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="font-heading font-bold text-4xl lg:text-5xl text-heading">Munkahelyi elsősegélynyújtó tanfolyam</h1>
        <p class="mt-4 text-lg text-body leading-relaxed">
          Minden munkahely minden műszakjában szükséges képzett elsősegélynyújtó.
          Intenzív, 4 órás, gyakorlatorientált képzésünket már több mint 1.000-en sikeresen teljesítették.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="/kapcsolat/" class="inline-flex items-center px-8 py-4 bg-orange text-white font-heading font-bold rounded-lg hover:bg-orange-dark transition-colors">Tanfolyam szervezése</a>
          <a href="tel:+36704098764" class="inline-flex items-center px-8 py-4 border-2 border-teal text-teal font-heading font-bold rounded-lg hover:bg-teal hover:text-white transition-colors">+36 70 409 8764</a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto space-y-8">
        <div class="grid md:grid-cols-3 gap-6">
          {[
            { title: 'Időtartam', value: '4 óra', desc: 'Intenzív, gyakorlatorientált' },
            { title: 'Ár', value: '24.900 Ft + ÁFA', desc: 'Személyenként' },
            { title: 'Résztvevők', value: '1.000+', desc: 'Sikeres teljesítő eddig' },
          ].map((item) => (
            <div class="bg-surface rounded-xl p-6 border border-border text-center" data-animate>
              <div class="font-heading font-bold text-2xl text-teal">{item.value}</div>
              <h3 class="font-heading font-semibold text-heading mt-2">{item.title}</h3>
              <p class="mt-1 text-muted text-sm">{item.desc}</p>
            </div>
          ))}
        </div>

        <h2 class="font-heading font-bold text-2xl text-heading">Mit tartalmaz a képzés?</h2>
        <div class="grid md:grid-cols-2 gap-6">
          {[
            { title: 'Elméleti oktatás', desc: 'Életmentő beavatkozások, sürgősségi helyzetek felismerése, teendők balesetnél.' },
            { title: 'Gyakorlat AMBU-Man babával', desc: 'Újraélesztés gyakorlása professzionális gyakorlóbabán, valós szituációk szimulálása.' },
            { title: 'Defibrillátor-használat', desc: 'AED (automata külső defibrillátor) használatának elsajátítása gyakorlati környezetben.' },
            { title: 'Jogszabályi háttér', desc: 'A 3/2002.(II.8.) SzCsM-EüM rendelet követelményeinek ismertetése.' },
          ].map((item) => (
            <div class="bg-surface rounded-xl p-6 border border-border" data-animate>
              <h3 class="font-heading font-semibold text-heading">{item.title}</h3>
              <p class="mt-2 text-body text-sm">{item.desc}</p>
            </div>
          ))}
        </div>

        <div class="bg-orange-light rounded-xl p-6 border border-orange/20">
          <h3 class="font-heading font-semibold text-heading">Helyszíni képzés, az Ön cégénél</h3>
          <p class="mt-2 text-body text-sm">
            A tanfolyamot az Ön telephelyén tartjuk meg – az eszközöket mi biztosítjuk.
            Minimális létszám és szervezési kérdések egyeztetéséhez kérjük, vegye fel velünk a kapcsolatot.
          </p>
        </div>
      </div>
    </div>
  </section>

  <ContactForm inline />
</PageLayout>
