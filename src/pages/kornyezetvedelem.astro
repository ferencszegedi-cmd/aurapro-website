---
import PageLayout from '../layouts/PageLayout.astro';
import QuoteBand from '../components/QuoteBand.astro';
import FaqAccordion from '../components/FaqAccordion.astro';

const services = [
  { title: 'Hulladékgazdálkodás', desc: 'Hulladékgazdálkodási terv, nyilvántartás, éves adatszolgáltatás (HIR), hulladékszállítás szervezése.' },
  { title: 'Környezetvédelmi engedélyek', desc: 'Egységes környezethasználati engedély (EKHE), környezeti hatásvizsgálat, bejelentés-köteles tevékenységek.' },
  { title: 'Zajmérés és zajvédelem', desc: 'Környezeti zajmérés, zajterhelési térkép, intézkedési terv a határértékek betartásához.' },
  { title: 'Levegőtisztaság-védelem', desc: 'Légszennyező források bejelentése, éves adatszolgáltatás, mérési programok szervezése.' },
  { title: 'Vízvédelem', desc: 'Vízjogi engedélyek, szennyvíz-kibocsátási határértékek ellenőrzése, mintavétel szervezése.' },
  { title: 'Hatósági kapcsolattartás', desc: 'Környezetvédelmi hatósági ellenőrzéseknél teljes körű képviselet és ügyintézés.' },
];

const faqItems = [
  { question: 'Mikor kell hulladékgazdálkodási tervet készíteni?', answer: 'Ha a vállalkozás évi 200 tonnánál több nem veszélyes, vagy bármennyi veszélyes hulladékot termel.' },
  { question: 'Mi az a HIR adatszolgáltatás?', answer: 'A Hulladékgazdálkodási Információs Rendszeren keresztül kötelező éves adatszolgáltatás a keletkezett és kezelt hulladékokról.' },
  { question: 'Mekkora bírság járhat környezetvédelmi jogsértésért?', answer: 'Környezetvédelmi bírság akár több tízmillió forintig terjedhet, és a tevékenység felfüggesztésével is járhat.' },
];

// P0-4: Service + FAQPage JSON-LD
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Környezetvédelmi szolgáltatás',
  provider: { '@type': 'Organization', name: 'Aurapro Kft.', url: 'https://www.aurapro.hu' },
  areaServed: { '@type': 'Country', name: 'Hungary' },
  description: 'Környezetvédelmi szolgáltatás: hulladékgazdálkodás, engedélyek, zajmérés, levegőtisztaság-védelem, vízvédelem.',
  url: 'https://www.aurapro.hu/kornyezetvedelem/',
};
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
---

<PageLayout
  title="Környezetvédelem – Aurapro | Hulladékgazdálkodás, engedélyek, zajmérés"
  description="Környezetvédelmi szolgáltatás: hulladékgazdálkodás, engedélyek, zajmérés, levegőtisztaság-védelem, vízvédelem. Egy kézből, hatóságra felkészítve."
  canonical="/kornyezetvedelem/"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)} />

  <!-- Page hero -->
  <section class="py-16 lg:py-24 bg-gradient-to-br from-teal-light to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="font-heading font-bold text-4xl lg:text-5xl text-heading">Környezetvédelem</h1>
        <p class="mt-4 text-lg text-body leading-relaxed">
          Hulladékgazdálkodástól a levegőtisztaság-védelmi adatszolgáltatásig –
          teljes környezetvédelmi megfelelés egy partnerrel.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="/kapcsolat/" class="inline-flex items-center px-8 py-4 bg-orange text-white font-heading font-bold rounded-lg hover:bg-orange-dark transition-colors">
            Ingyenes ajánlat kérése
          </a>
          <div class="inline-flex flex-col items-center px-8 py-4 border-2 border-teal text-teal font-heading font-bold rounded-lg">
            <span>Hívjon most</span>
            <span class="text-[1.1rem] font-normal text-teal/80 mt-1">+36 70 409 8764</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services grid -->
  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading font-bold text-3xl lg:text-4xl text-heading text-center mb-12">Környezetvédelmi szolgáltatásaink</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((s) => (
          <div class="bg-surface rounded-xl p-6 border border-border">
            <div class="w-10 h-10 rounded-lg bg-teal-light flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
              </svg>
            </div>
            <h3 class="font-heading font-semibold text-heading">{s.title}</h3>
            <p class="mt-2 text-body text-sm leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Info band -->
  <section class="py-12 lg:py-16 bg-teal-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading font-bold text-2xl lg:text-3xl text-white">Komplex megoldás: MV + TV + KV egy kézből</h2>
      <p class="mt-3 text-white/80 text-lg max-w-2xl mx-auto">
        A munka-, tűz- és környezetvédelem együtt kezelve hatékonyabb és olcsóbb.
        Egy partner, egy szerződés – kevesebb adminisztráció.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading font-bold text-3xl text-heading text-center mb-10">Gyakori kérdések a környezetvédelemről</h2>
      <div class="max-w-3xl mx-auto">
        <FaqAccordion items={faqItems} />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <QuoteBand formSource="band-kornyezetvedelem" services={['kornyezetvedelem']} />
</PageLayout>
