---
import PageLayout from '../layouts/PageLayout.astro';
import QuoteBand from '../components/QuoteBand.astro';
import { Image } from 'astro:assets';
import serviceMv from '../assets/images/service-munkavedelem.jpg';

// P0-4: Service JSON-LD
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Munkavédelmi kockázatértékelés',
  provider: { '@type': 'Organization', name: 'Aurapro Kft.', url: 'https://www.aurapro.hu' },
  areaServed: { '@type': 'Country', name: 'Hungary' },
  description: 'Munkahelyi kockázatértékelés készítése munkakörönként, veszélyes anyagokra és munkaeszközökre, jogszabályi megfeleléshez.',
  url: 'https://www.aurapro.hu/kockazatertekeles/',
};
---

<PageLayout
  title="Munkavédelmi kockázatértékelés készítés | Aurapro"
  description="Jogszabályi kötelező kockázatértékelés szakértőtől, munkakörönként, fix áron. Átalánydíjas szerződésnél benne van. Kérjen ajánlatot."
  canonical="/kockazatertekeles/"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(serviceSchema)} />

  <section class="py-16 lg:py-24 bg-gradient-to-br from-teal-light to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h1 class="font-heading font-bold text-4xl lg:text-5xl text-heading">Kockázatértékelés</h1>
          <p class="mt-4 text-lg text-body leading-relaxed">
            A kockázatértékelés annak vizsgálata, hogy az adott munkahely milyen mértékben felel meg
            a jogszabályi előírásoknak. Mi átlátható, a konkrét munkahelyre szabott dokumentációt készítünk.
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href="/kapcsolat/" class="inline-flex items-center px-8 py-4 bg-orange text-white font-heading font-bold rounded-lg hover:bg-orange-dark transition-colors">Ingyenes ajánlat kérése</a>
            <div class="inline-flex flex-col items-center px-8 py-4 border-2 border-teal text-teal font-heading font-bold rounded-lg">
            <span>Hívjon most</span>
            <span class="text-[1.1rem] font-normal text-teal/80 mt-1">+36 70 409 8764</span>
          </div>
          </div>
        </div>
        <div class="hidden lg:block">
          <Image src={serviceMv} alt="Kockázatértékelés munkahelyen – szakértő gépátvizsgálás közben" widths={[640, 1024]} sizes="(min-width: 1024px) 50vw, 100vw" class="rounded-2xl shadow-lg" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto space-y-8">
        <h2 class="font-heading font-bold text-3xl text-heading">Mit tartalmaz a kockázatértékelés?</h2>
        <div class="grid md:grid-cols-2 gap-6">
          {[
            { title: 'Munkakör-elemzés', desc: 'Minden munkakör egyedi veszélyeinek feltérképezése és értékelése.' },
            { title: 'Veszélyes anyagok', desc: 'Vegyi anyagok, porok, gőzök azonosítása és az expozíció értékelése.' },
            { title: 'Munkaeszközök vizsgálata', desc: 'Gépek, szerszámok, berendezések kockázatainak felmérése.' },
            { title: 'Intézkedési terv', desc: 'Konkrét javaslatok a feltárt kockázatok csökkentésére vagy megszüntetésére.' },
          ].map((item) => (
            <div class="bg-surface rounded-xl p-6 border border-border" data-animate>
              <h3 class="font-heading font-semibold text-heading">{item.title}</h3>
              <p class="mt-2 text-body text-sm">{item.desc}</p>
            </div>
          ))}
        </div>

        <div class="bg-orange-light rounded-xl p-6 border border-orange/20">
          <h3 class="font-heading font-semibold text-heading">Átalánydíjas szerződésnél a kockázatértékelés nem kerül külön díjba</h3>
          <p class="mt-2 text-body text-sm">
            Ellentétben sok piaci szereplővel, nálunk a kockázatértékelés elkészítése és naprakészen tartása
            az átalánydíj része – nem számítunk fel érte külön költséget.
          </p>
        </div>

        <h2 class="font-heading font-bold text-2xl text-heading">Mikor kell felülvizsgálni?</h2>
        <ul class="space-y-3">
          {[
            'Új munkakör létrehozásakor',
            'Új munkaeszköz vagy technológia bevezetésekor',
            'Munkabaleset bekövetkezése után',
            'Legalább 5 évente kötelezően',
            'Jogszabályi változások esetén',
          ].map((item) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              <span class="text-body">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <QuoteBand formSource="band-kockazatertekeles" services={['munkavedelem']} />
</PageLayout>
