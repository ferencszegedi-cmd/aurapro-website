---
import PageLayout from '../layouts/PageLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<PageLayout
  title="Kapcsolat – Aurapro | Ingyenes ajánlatkérés"
  description="Kérjen ingyenes felmérést és ajánlatot! 24 órán belül visszahívjuk. Telefon, email, vagy töltse ki az űrlapot."
  canonical="/kapcsolat/"
>
  <!-- Page hero -->
  <section class="py-16 lg:py-24 bg-gradient-to-br from-teal-light to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="font-heading font-bold text-4xl lg:text-5xl text-heading">Kapcsolat</h1>
        <p class="mt-4 text-lg text-body leading-relaxed">
          Kérjen ingyenes felmérést – kötelezettségmentesen! 24 órán belül személyre szabott ajánlatot küldünk.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact section -->
  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">

        <!-- Form -->
        <div>
          <h2 class="font-heading font-bold text-2xl text-heading mb-6">Írjon nekünk</h2>
          <ContactForm />
        </div>

        <!-- Contact info -->
        <div>
          <h2 class="font-heading font-bold text-2xl text-heading mb-6">Elérhetőségek</h2>

          <div class="space-y-6">
            <div class="flex gap-4">
              <div class="shrink-0 w-10 h-10 rounded-full bg-teal-light flex items-center justify-center">
                <svg class="w-5 h-5 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-heading font-semibold text-heading">Telefon</h3>
                <a href="tel:+36704098764" class="text-teal hover:text-teal-dark transition-colors">+36 70 409 8764</a>
                <p class="text-sm text-muted mt-1">H-P: 8:00 – 17:00</p>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="shrink-0 w-10 h-10 rounded-full bg-teal-light flex items-center justify-center">
                <svg class="w-5 h-5 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-heading font-semibold text-heading">Email</h3>
                <a href="mailto:katalin.szuk@aurapro.hu" class="text-teal hover:text-teal-dark transition-colors">katalin.szuk@aurapro.hu</a>
                <p class="text-sm text-muted mt-1">24 órán belül válaszolunk</p>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="shrink-0 w-10 h-10 rounded-full bg-teal-light flex items-center justify-center">
                <svg class="w-5 h-5 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-heading font-semibold text-heading">Iroda</h3>
                <p class="text-body">2040 Budaörs, Gyár utca 2.</p>
                <p class="text-sm text-muted mt-1">BITEP Ipari Park</p>
              </div>
            </div>
          </div>

          <!-- Trust signals -->
          <div class="mt-10 p-6 bg-surface rounded-xl border border-border">
            <h3 class="font-heading font-semibold text-heading mb-3">Miért válasszon minket?</h3>
            <ul class="space-y-2 text-body text-sm">
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 text-teal shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                Ingyenes felmérés és ajánlat
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 text-teal shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                40 millió Ft bírsággarancia
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 text-teal shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                24 órán belüli visszahívás
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 text-teal shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                Kötelezettségmentes konzultáció
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
