          </a>
        </div>
        <div class="hidden lg:block">
          <Image src={iparagak} alt="Modern industrial park: manufacturing hall, logistics warehouse, office building and a construction site with a tower crane" widths={[640, 1024, 1600]} sizes="(min-width: 1024px) 50vw, 100vw" class="rounded-2xl shadow-lg" loading="lazy" />
        </div>
      </div>
    </div>
