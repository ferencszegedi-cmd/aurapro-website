---
import PageLayout from '../../layouts/PageLayout.astro';
import QuoteBand from '../../components/QuoteBand.astro';
import FaqAccordion from '../../components/FaqAccordion.astro';

const services = [
  { title: 'Risk assessment', desc: 'Job-by-job risk analysis and an action plan for legal compliance.' },
  { title: 'Occupational safety training', desc: 'Organising and documenting annual and ad-hoc training – online too, if needed.' },
  { title: 'Safety policies', desc: 'Tailored documents: occupational safety policy, personal protective equipment allocation rules, medical fitness examination rules, a unified prevention strategy, operational documentation, work instructions.' },
  { title: 'Safety coordinator', desc: 'A dedicated expert who regularly oversees safety compliance and liaises with the authorities.' },
  { title: 'Official administration', desc: 'Full representation during occupational safety inspections and proceedings.' },
  { title: 'Accident investigation', desc: 'Preparing accident reports and action plans, and handling official notifications.' },
];

const faqItems = [
  { question: 'When is it mandatory to employ an occupational safety professional?', answer: 'Every employer must provide for occupational safety tasks if it employs at least one worker. These tasks can also be carried out via a contracted expert.' },
  { question: 'How often is occupational safety training required?', answer: 'At least once a year, and additionally on an ad-hoc basis when a job role changes, a new technology is introduced, or after a workplace accident.' },
  { question: 'What happens at an inspection if we have no policy?', answer: 'The authority can impose a fine from HUF 100,000 up to as much as HUF 100 million (Gov. Decree 25/2024; the upper limit is HUF 25–50 million for SMEs) and may order immediate measures.' },
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Occupational safety service',
  provider: { '@type': 'Organization', name: 'Aurapro Kft.', url: 'https://www.aurapro.hu' },
  areaServed: { '@type': 'Country', name: 'Hungary' },
  description: 'Comprehensive occupational safety service: risk assessment, training, policies, coordinator, official representation.',
  url: 'https://www.aurapro.hu/en/occupational-safety/',
};
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
---

<PageLayout
  lang="en"
  title="Occupational safety in Budapest and nationwide | Aurapro"
  description="Comprehensive occupational safety service for companies: risk assessment, training, policies, coordinator, official representation. HUF 40M penalty guarantee. Request a quote."
  canonical="/en/occupational-safety/"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)} />

  <!-- Page hero -->
  <section class="py-16 lg:py-24 bg-gradient-to-br from-teal-light to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="font-heading font-bold text-4xl lg:text-5xl text-heading">Occupational safety</h1>
        <p class="mt-4 text-lg text-body leading-relaxed">
          A full-service occupational safety solution – from risk assessment to official representation.
          Our 30 experts ensure your company's legal compliance nationwide.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="/en/contact/" class="inline-flex items-center px-8 py-4 bg-orange text-white font-heading font-bold rounded-lg hover:bg-orange-dark transition-colors">
            Request a free quote
          </a>
          <div class="inline-flex flex-col items-center px-8 py-4 border-2 border-teal text-teal font-heading font-bold rounded-lg">
            <span>Call now</span>
            <span class="text-[1.1rem] font-normal text-teal/80 mt-1">+36 70 409 8764</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services grid -->
  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading font-bold text-3xl lg:text-4xl text-heading text-center mb-12">Our occupational safety services</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((s) => (
          <div class="bg-surface rounded-xl p-6 border border-border">
            <div class="w-10 h-10 rounded-lg bg-teal-light flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <h3 class="font-heading font-semibold text-heading">{s.title}</h3>
            <p class="mt-2 text-body text-sm leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Guarantee band -->
  <section class="py-12 lg:py-16 bg-teal-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading font-bold text-2xl lg:text-3xl text-white">HUF 40 million penalty guarantee</h2>
      <p class="mt-3 text-white/80 text-lg max-w-2xl mx-auto">
        We are so confident in our work that we commit: if a partner is fined due to our negligence,
        we reimburse the amount of the fine – up to HUF 40 million.
      </p>
      <a href="/biztositasi-garancia.pdf" target="_blank" rel="noopener noreferrer" class="mt-6 inline-flex items-center px-6 py-3 border-2 border-white/30 text-white font-heading font-semibold rounded-lg hover:bg-white/10 transition-colors">
        View the insurance guarantee (PDF)
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
      </a>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading font-bold text-3xl text-heading text-center mb-10">Common occupational safety questions</h2>
      <div class="max-w-3xl mx-auto">
        <FaqAccordion items={faqItems} />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <QuoteBand formSource="band-occupational-safety-en" services={['munkavedelem']} lang="en" />
</PageLayout>
