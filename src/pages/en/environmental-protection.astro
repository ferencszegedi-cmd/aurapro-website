---
import PageLayout from '../../layouts/PageLayout.astro';
import QuoteBand from '../../components/QuoteBand.astro';
import FaqAccordion from '../../components/FaqAccordion.astro';

const services = [
  { title: 'Waste management', desc: 'Waste management plan, records, annual data reporting (HIR), and organising waste transport.' },
  { title: 'Environmental permits', desc: 'Integrated environmental permit (IPPC/EKHE), environmental impact assessment, notification-based activities.' },
  { title: 'Noise measurement & protection', desc: 'Environmental noise measurement, noise-load maps, and an action plan to stay within the limits.' },
  { title: 'Air quality protection', desc: 'Reporting air pollution sources, annual data reporting, and organising measurement programmes.' },
  { title: 'Water protection', desc: 'Water permits, checking wastewater emission limits, and organising sampling.' },
  { title: 'Liaising with authorities', desc: 'Full representation and administration during environmental inspections.' },
];

const faqItems = [
  { question: 'When is a waste management plan required?', answer: 'If the company produces more than 200 tonnes of non-hazardous waste per year, or any amount of hazardous waste.' },
  { question: 'What is the HIR data report?', answer: 'A mandatory annual data report on the waste produced and treated, submitted via the Waste Management Information System (HIR).' },
  { question: 'How large a fine can be imposed for an environmental breach?', answer: 'An environmental fine can run to several tens of millions of forints and may also involve suspension of the activity.' },
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Environmental protection service',
  provider: { '@type': 'Organization', name: 'Aurapro Kft.', url: 'https://www.aurapro.hu' },
  areaServed: { '@type': 'Country', name: 'Hungary' },
  description: 'Environmental protection service: waste management, permits, noise measurement, air quality protection, water protection.',
  url: 'https://www.aurapro.hu/en/environmental-protection/',
};
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
---

<PageLayout
  lang="en"
  title="Environmental protection – Aurapro | Waste management, permits, noise measurement"
  description="Environmental protection service: waste management, permits, noise measurement, air quality protection, water protection. From a single provider, prepared for the authorities."
  canonical="/en/environmental-protection/"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)} />

  <!-- Page hero -->
  <section class="py-16 lg:py-24 bg-gradient-to-br from-teal-light to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="font-heading font-bold text-4xl lg:text-5xl text-heading">Environmental protection</h1>
        <p class="mt-4 text-lg text-body leading-relaxed">
          From waste management to air quality data reporting –
          full environmental compliance with a single partner.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="/en/contact/" class="inline-flex items-center px-8 py-4 bg-orange text-white font-heading font-bold rounded-lg hover:bg-orange-dark transition-colors">
            Request a free quote
          </a>
          <div class="inline-flex flex-col items-center px-8 py-4 border-2 border-teal text-teal font-heading font-bold rounded-lg">
            <span>Call now</span>
            <span class="text-[1.1rem] font-normal text-teal/80 mt-1">+36 70 409 8764</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services grid -->
  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading font-bold text-3xl lg:text-4xl text-heading text-center mb-12">Our environmental protection services</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((s) => (
          <div class="bg-surface rounded-xl p-6 border border-border">
            <div class="w-10 h-10 rounded-lg bg-teal-light flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
              </svg>
            </div>
            <h3 class="font-heading font-semibold text-heading">{s.title}</h3>
            <p class="mt-2 text-body text-sm leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Info band -->
  <section class="py-12 lg:py-16 bg-teal-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading font-bold text-2xl lg:text-3xl text-white">A complete solution: occupational + fire + environmental from one provider</h2>
      <p class="mt-3 text-white/80 text-lg max-w-2xl mx-auto">
        Handling occupational, fire and environmental safety together is more efficient and cheaper.
        One partner, one contract – less administration.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading font-bold text-3xl text-heading text-center mb-10">Common environmental protection questions</h2>
      <div class="max-w-3xl mx-auto">
        <FaqAccordion items={faqItems} />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <QuoteBand formSource="band-environmental-en" services={['kornyezetvedelem']} lang="en" />
</PageLayout>
