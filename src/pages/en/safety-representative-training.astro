---
import PageLayout from '../../layouts/PageLayout.astro';
import QuoteBand from '../../components/QuoteBand.astro';
import { Image } from 'astro:assets';
import serviceOktatas from '../../assets/images/service-oktatas.jpg';
---

<PageLayout
  lang="en"
  title="Safety representative training – Aurapro | Basic and further training"
  description="Accredited safety representative training online and in person. A 94.8% pass rate and legal compliance. HUF 38,800/person (VAT-exempt)."
  canonical="/en/safety-representative-training/"
>
  <section class="py-16 lg:py-24 bg-gradient-to-br from-teal-light to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h1 class="font-heading font-bold text-4xl lg:text-5xl text-heading">Safety representative training</h1>
          <p class="mt-4 text-lg text-body leading-relaxed">
            We help you complete the basic and further training quickly and flexibly!
            Our specialists, with years of teaching and daily hands-on experience,
            prepare safety representatives to represent employee interests as
            effectively as possible.
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href="/en/contact/" class="inline-flex items-center px-8 py-4 bg-orange text-white font-heading font-bold rounded-lg hover:bg-orange-dark transition-colors">Arrange training</a>
            <div class="inline-flex flex-col items-center px-8 py-4 border-2 border-teal text-teal font-heading font-bold rounded-lg">
            <span>Call now</span>
            <span class="text-[1.1rem] font-normal text-teal/80 mt-1">+36 70 409 8764</span>
          </div>
          </div>
        </div>
        <div class="hidden lg:block">
          <Image src={serviceOktatas} alt="Safety representative training in a training room" widths={[640, 1024]} sizes="(min-width: 1024px) 50vw, 100vw" class="rounded-2xl shadow-lg" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto space-y-8">
        <div class="grid md:grid-cols-3 gap-6">
          {[
            { title: 'Basic training', value: '16 hours', desc: 'Within 1 year of election' },
            { title: 'Further training', value: '8 hours/year', desc: 'Mandatory annually' },
            { title: 'Pass rate', value: '94.8%', desc: 'On the first attempt' },
          ].map((item) => (
            <div class="bg-surface rounded-xl p-6 border border-border text-center" data-animate>
              <div class="font-heading font-bold text-2xl text-teal">{item.value}</div>
              <h3 class="font-heading font-semibold text-heading mt-2">{item.title}</h3>
              <p class="mt-1 text-muted text-sm">{item.desc}</p>
            </div>
          ))}
        </div>

        <h2 class="font-heading font-bold text-2xl text-heading">Legal background</h2>
        <p class="text-body leading-relaxed">
          Under Section 75(1)(c) of the Occupational Safety Act, within one election cycle the employer must
          provide the safety representative with the opportunity to take part in at least <strong>16 hours of basic training</strong>
          within one year of election, and thereafter at least <strong>8 hours of further training</strong> each year.
        </p>

        <h2 class="font-heading font-bold text-2xl text-heading">Features of our accredited training</h2>
        <ul class="space-y-3">
          {[
            'Course material built on practical, real-world examples',
            'Training material developed by occupational safety engineers, meeting the legal requirements',
            'Easy-to-understand, logically structured training',
            'A 94.8% pass rate on the first attempt at the tests',
            'Available both online and in person',
          ].map((item) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              <span class="text-body">{item}</span>
            </li>
          ))}
        </ul>

        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-surface rounded-xl p-6 border border-border" data-animate>
            <h3 class="font-heading font-semibold text-heading">Online training</h3>
            <p class="mt-2 text-body text-sm">
              As an innovative company we value digitalisation, so our training is also available
              online – conveniently, completable from anywhere.
            </p>
          </div>
          <div class="bg-surface rounded-xl p-6 border border-border" data-animate>
            <h3 class="font-heading font-semibold text-heading">In-person training</h3>
            <p class="mt-2 text-body text-sm">
              On-site training at your company or in Budaörs, at the BITEP Industrial Park.
              We issue a certificate of completion.
            </p>
          </div>
        </div>

        <div class="bg-orange-light rounded-xl p-6 border border-orange/20">
          <h3 class="font-heading font-semibold text-heading">Course price: HUF 38,800/person (VAT-exempt)</h3>
          <p class="mt-2 text-body text-sm">
            Registration and more information: <a href="mailto:dora.szabo@aurapro.hu" class="text-teal font-medium hover:text-teal-dark">dora.szabo@aurapro.hu</a>
          </p>
          <p class="mt-1 text-body text-sm">
            Accreditation licence number: E-001910/2019
          </p>
        </div>
      </div>
    </div>
  </section>

  <QuoteBand formSource="band-rep-training-en" services={['mv-kepviselo']} lang="en" />
</PageLayout>
