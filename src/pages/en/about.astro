---
import PageLayout from '../../layouts/PageLayout.astro';
import QuoteBand from '../../components/QuoteBand.astro';
---

<PageLayout
  lang="en"
  title="About us – Aurapro | Occupational, fire and environmental safety provider"
  description="For nearly 20 years Aurapro Kft. has ensured its partners' occupational safety compliance. 30 experts, the safety of 15,000+ employees, a HUF 40M penalty guarantee."
  canonical="/en/about/"
>
  <!-- Hero -->
  <section class="py-16 lg:py-24 bg-gradient-to-br from-teal-light to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="font-heading font-bold text-4xl lg:text-5xl text-heading">About us</h1>
        <p class="mt-4 text-lg text-body leading-relaxed">
          Aurapro Kft. is one of Hungary's leading occupational, fire and environmental safety providers.
          For nearly 20 years we have helped our partners meet legal requirements – not one of our clients has ever been fined.
        </p>
      </div>
    </div>
  </section>

  <!-- Numbers -->
  <section class="py-12 lg:py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-5 gap-8 text-center">
        {[
          { number: '~20', label: 'years of experience' },
          { number: '30', label: 'experts nationwide' },
          { number: '15,000+', label: 'employees kept safe' },
          { number: '48+', label: 'enterprise partners' },
          { number: '0', label: 'fines to date' },
        ].map((stat, i) => (
          <div data-animate data-animate-delay={i + 1}>
            <div class="font-heading font-bold text-3xl lg:text-4xl text-teal">{stat.number}</div>
            <div class="mt-1 text-muted text-sm">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Who we are -->
  <section class="py-16 lg:py-20 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-heading font-bold text-3xl text-heading mb-8">Why Aurapro?</h2>
        <div class="space-y-6 text-body leading-relaxed">
          <p>
            We founded our company in the belief that occupational safety is not merely a bureaucratic
            obligation, but an activity that protects the lives and health of workers and creates real value.
            Today, our 30 experts safeguard more than 15,000 employees across the entire country.
          </p>
          <p>
            We specialise in companies with at least 100 employees, where managing complex safety tasks
            requires genuine expertise and dedicated attention. Our partners include the largest
            Hungarian and multinational companies – from Audi to Siemens, from Richter to Primark.
          </p>
          <p>
            We are so confident in our work that we offer a unique guarantee:
            a <strong>HUF 40 million penalty guarantee</strong> for every partner.
            This is not just a promise – it is covered by our professional liability insurance.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Insurance guarantee (Allianz policy) -->
  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-10">
          <h2 class="font-heading font-bold text-3xl text-heading">Insurance guarantee – in black and white</h2>
          <p class="mt-3 text-body text-lg">
            The official Allianz policy below covers our HUF 40 million penalty guarantee.
            Click the image to view the full 3-page document.
          </p>
        </div>
        <div class="flex justify-center">
          <a href="/biztositasi-garancia.pdf" target="_blank" rel="noopener noreferrer"
            class="group relative block max-w-md mx-auto rounded-xl overflow-hidden shadow-lg hover:shadow-2xl border border-border transition-all duration-300 hover:scale-[1.02]"
            aria-label="View the insurance policy (PDF, 3 pages)">
            <img src="/images/kotveny-elso-oldal.jpg" alt="Allianz insurance policy (324750636) – first page"
              class="w-full h-auto" loading="lazy" />
            <div class="absolute inset-0 bg-teal/0 group-hover:bg-teal/20 transition-colors duration-300 flex items-center justify-center">
              <div class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-white rounded-lg shadow-lg px-6 py-3 flex items-center gap-2">
                <svg class="w-5 h-5 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                </svg>
                <span class="font-heading font-semibold text-heading text-sm">View the full policy</span>
              </div>
            </div>
          </a>
        </div>
        <p class="mt-4 text-center text-muted text-sm">
          Policy number: <strong>324750636</strong> · Allianz Hungária Zrt. ·
          Limit/event: HUF 20,000,000 · Limit/period: HUF 40,000,000
        </p>
      </div>
    </div>
  </section>

  <!-- How we work -->
  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading font-bold text-3xl text-heading text-center mb-12">How we work</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-5xl mx-auto">
        {[
          {
            title: 'Fixed flat fee',
            desc: 'A predictable, fixed monthly fee – no hidden costs; risk assessment and training are included in the price.',
            icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
          },
          {
            title: 'Nationwide coverage',
            desc: 'We are present in every county – fast on-site response and local knowledge of the authorities.',
            icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z',
          },
          {
            title: 'A dedicated expert',
            desc: 'Every partner has an assigned contact person who knows the specifics of the company.',
            icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z',
          },
          {
            title: 'A complete service',
            desc: 'Occupational, fire and environmental safety from a single provider – less coordination, more efficiency.',
            icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
          },
          {
            title: 'Rapid response',
            desc: 'Official inspection, workplace accident, an urgent problem – our experts respond quickly and effectively.',
            icon: 'M13 10V3L4 14h7v7l9-11h-7z',
          },
          {
            title: 'HUF 40M penalty guarantee',
            desc: 'If a partner is fined due to our negligence, we reimburse the amount of the fine – covered by insurance.',
            icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
          },
        ].map((item) => (
          <div class="flex gap-4" data-animate>
            <div class="shrink-0 w-12 h-12 rounded-lg bg-teal-light flex items-center justify-center">
              <svg class="w-6 h-6 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon}/>
              </svg>
            </div>
            <div>
              <h3 class="font-heading font-semibold text-heading">{item.title}</h3>
              <p class="mt-1 text-body text-sm">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact details -->
  <section class="py-16 lg:py-20 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-heading font-bold text-3xl text-heading mb-8">Get in touch</h2>
        <div class="grid md:grid-cols-2 gap-8">
          <div class="space-y-4">
            <div class="flex gap-3">
              <svg class="w-5 h-5 text-teal shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              <div>
                <p class="font-heading font-semibold text-heading">Head office</p>
                <p class="text-body text-sm">2040 Budaörs, Gyár utca 2., Hungary</p>
                <p class="text-muted text-sm">BITEP Industrial Park</p>
              </div>
            </div>
            <div class="flex gap-3">
              <svg class="w-5 h-5 text-teal shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              <div>
                <p class="font-heading font-semibold text-heading">Phone</p>
                <a href="tel:+36704098764" class="text-teal hover:text-teal-dark transition-colors">+36 70 409 8764</a>
              </div>
            </div>
            <div class="flex gap-3">
              <svg class="w-5 h-5 text-teal shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              <div>
                <p class="font-heading font-semibold text-heading">Email</p>
                <a href="mailto:iroda@aurapro.hu" class="text-teal hover:text-teal-dark transition-colors">iroda@aurapro.hu</a>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl border border-border p-6">
            <p class="font-heading font-semibold text-heading mb-3">Request a quote</p>
            <p class="text-body text-sm mb-4">Request a free assessment! We will send a tailored quote within 24 hours.</p>
            <a href="/en/contact/" class="inline-flex items-center px-6 py-3 bg-orange text-white font-heading font-semibold rounded-lg hover:bg-orange-dark transition-colors">
              Request a quote
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <QuoteBand formSource="band-about-en" lang="en" />
</PageLayout>
