---
import PageLayout from '../layouts/PageLayout.astro';
import QuoteBand from '../components/QuoteBand.astro';
import { Image } from 'astro:assets';
import serviceTv from '../assets/images/service-tuzvedelem.jpg';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Tűzvédelmi oktatás',
  provider: { '@type': 'Organization', name: 'Aurapro Kft.', url: 'https://www.aurapro.hu' },
  areaServed: { '@type': 'Country', name: 'Hungary' },
  description: 'Éves tűzvédelmi oktatás 30-60 perc, dokumentált, jogszabálykövető. Munkavédelmi oktatással összevonható.',
  url: 'https://www.aurapro.hu/tuzvedelmi-oktatas/',
};
---

<PageLayout
  title="Tűzvédelmi oktatás – Aurapro | Jogszabálykövető, dokumentált"
  description="Tűzvédelmi oktatás évente, munkavédelmi oktatással összevonható. 30-60 perc, dokumentált. Hiánya 30.000–1.500.000 Ft bírsággal járhat."
  canonical="/tuzvedelmi-oktatas/"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(serviceSchema)} />

  <section class="py-16 lg:py-24 bg-gradient-to-br from-orange-light to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h1 class="font-heading font-bold text-4xl lg:text-5xl text-heading">Tűzvédelmi oktatás</h1>
          <p class="mt-4 text-lg text-body leading-relaxed">
            A tűzvédelmi oktatás célja, hogy a munkavállalók ismerjék a tűzmegelőzési szabályokat,
            a menekülési útvonalakat és a tűzoltó eszközök használatát. Nálunk valódi oktatást kap – nem csupán aláírásgyűjtést.
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href="/kapcsolat/" class="inline-flex items-center px-8 py-4 bg-orange text-white font-heading font-bold rounded-lg hover:bg-orange-dark transition-colors">Ingyenes ajánlat kérése</a>
            <div class="inline-flex flex-col items-center px-8 py-4 border-2 border-teal text-teal font-heading font-bold rounded-lg">
            <span>Hívjon most</span>
            <span class="text-[1.1rem] font-normal text-teal/80 mt-1">+36 70 409 8764</span>
          </div>
          </div>
        </div>
        <div class="hidden lg:block">
          <Image src={serviceTv} alt="Tűzvédelmi oktatás – tűzoltókészülék használatának bemutatása" widths={[640, 1024]} sizes="(min-width: 1024px) 50vw, 100vw" class="rounded-2xl shadow-lg" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto space-y-8">
        <div class="grid md:grid-cols-3 gap-6">
          {[
            { title: 'Időtartam', value: '30–60 perc', desc: 'Munkavédelmi oktatással összevonható' },
            { title: 'Gyakoriság', value: 'Évente', desc: 'Tűzeset vagy változás után soron kívül' },
            { title: 'Bírság hiány esetén', value: '30.000–1.500.000 Ft', desc: 'Katasztrófavédelem szabhatja ki' },
          ].map((item) => (
            <div class="bg-surface rounded-xl p-6 border border-border text-center" data-animate>
              <div class="font-heading font-bold text-xl text-teal">{item.value}</div>
              <h3 class="font-heading font-semibold text-heading mt-2">{item.title}</h3>
              <p class="mt-1 text-muted text-sm">{item.desc}</p>
            </div>
          ))}
        </div>

        <h2 class="font-heading font-bold text-2xl text-heading">Mikor kötelező?</h2>
        <ul class="space-y-3">
          {[
            'Munkába álláskor',
            'Új tűzveszélyes technológia bevezetésekor',
            'Tűzeset bekövetkezése után',
            'Kiürítési helyzet megváltozásakor',
            'Évente rendszeresen',
          ].map((item) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-orange-dark shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              <span class="text-body">{item}</span>
            </li>
          ))}
        </ul>

        <div class="bg-teal-light rounded-xl p-6 border border-teal/20">
          <h3 class="font-heading font-semibold text-heading">Praktikus megoldás: összevont oktatás</h3>
          <p class="mt-2 text-body text-sm">
            A tűzvédelmi és munkavédelmi oktatás összevonható, így egyetlen alkalommal mindkét kötelezettség teljesíthető.
            Ezzel időt és pénzt takarít meg, miközben a jogszabályi megfelelés biztosított.
          </p>
        </div>
      </div>
    </div>
  </section>

  <QuoteBand formSource="band-tv-oktatas" service="kepzes" />
</PageLayout>
