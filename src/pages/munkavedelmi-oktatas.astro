---
import PageLayout from '../layouts/PageLayout.astro';
import ContactForm from '../components/ContactForm.astro';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Munkavédelmi oktatás',
  provider: { '@type': 'Organization', name: 'Aurapro Kft.', url: 'https://www.aurapro.hu' },
  areaServed: { '@type': 'Country', name: 'Hungary' },
  description: 'Éves és rendkívüli munkavédelmi oktatások szervezése, dokumentálása – akár online formában is.',
  url: 'https://www.aurapro.hu/munkavedelmi-oktatas/',
};
---

<PageLayout
  title="Munkavédelmi oktatás – Aurapro | Éves és rendkívüli oktatások"
  description="Munkavédelmi oktatás profi szakemberekkel: 30-60 perc, dokumentált, jogszabálykövető. Hiánya esetén 100.000 Ft/fő bírság."
  canonical="/munkavedelmi-oktatas/"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(serviceSchema)} />

  <section class="py-16 lg:py-24 bg-gradient-to-br from-teal-light to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h1 class="font-heading font-bold text-4xl lg:text-5xl text-heading">Munkavédelmi oktatás</h1>
          <p class="mt-4 text-lg text-body leading-relaxed">
            A munkavédelmi oktatás a munkáltató egyik legfontosabb kötelezettsége. Mi nemcsak megtartjuk,
            hanem az összes kapcsolódó dokumentumot is elkészítjük – kockázatértékeléstől az egyéni védőeszköz juttatási rendig.
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href="/kapcsolat/" class="inline-flex items-center px-8 py-4 bg-orange text-white font-heading font-bold rounded-lg hover:bg-orange-dark transition-colors">Ingyenes ajánlat kérése</a>
            <a href="tel:+36704098764" class="inline-flex items-center px-8 py-4 border-2 border-teal text-teal font-heading font-bold rounded-lg hover:bg-teal hover:text-white transition-colors">+36 70 409 8764</a>
          </div>
        </div>
        <div class="hidden lg:block">
          <img src="/images/munkavedelmi-oktatas.jpg" alt="Munkavédelmi oktatás" class="rounded-2xl shadow-lg" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto space-y-8">
        <h2 class="font-heading font-bold text-3xl text-heading">Az oktatás részletei</h2>
        <div class="grid md:grid-cols-3 gap-6">
          {[
            { title: 'Időtartam', value: '30–60 perc', desc: 'Tömör, lényegre törő oktatás' },
            { title: 'Gyakoriság', value: 'Évente min. 1×', desc: 'Rendkívüli esetben soron kívül' },
            { title: 'Bírság hiány esetén', value: '100.000 Ft/fő', desc: 'Munkavállalónként szabható ki' },
          ].map((item) => (
            <div class="bg-surface rounded-xl p-6 border border-border text-center" data-animate>
              <div class="font-heading font-bold text-2xl text-teal">{item.value}</div>
              <h3 class="font-heading font-semibold text-heading mt-2">{item.title}</h3>
              <p class="mt-1 text-muted text-sm">{item.desc}</p>
            </div>
          ))}
        </div>

        <h2 class="font-heading font-bold text-2xl text-heading">Mikor kötelező megtartani?</h2>
        <ul class="space-y-3">
          {[
            'Munkába álláskor (előzetes oktatás)',
            'Munkakör vagy munkahely megváltozásakor',
            'Új technológia vagy munkaeszköz bevezetésekor',
            'Munkabaleset bekövetkezése után (soron kívüli)',
            'Évente legalább egyszer (ismétlődő oktatás)',
          ].map((item) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              <span class="text-body">{item}</span>
            </li>
          ))}
        </ul>

        <div class="bg-orange-light rounded-xl p-6 border border-orange/20">
          <h3 class="font-heading font-semibold text-heading">Nem csak oktatás – teljes dokumentáció</h3>
          <p class="mt-2 text-body text-sm">
            A jogszabályi megfeleléshez az oktatáson túl kockázatértékelés, egyéni védőeszköz juttatási rend,
            átfogó megelőzési stratégia és oktatási napló is szükséges. Mindezt mi elkészítjük és naprakészen tartjuk.
          </p>
        </div>
      </div>
    </div>
  </section>

  <ContactForm inline />
</PageLayout>
