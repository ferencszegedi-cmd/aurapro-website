---
import PageLayout from '../layouts/PageLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<PageLayout
  title="Rólunk – Aurapro | Munka-, tűz- és környezetvédelmi szolgáltató"
  description="Az Aurapro Kft. 13 éve biztosítja partnerei munkavédelmi megfelelését. 30 szakértő, 15.000+ munkavállaló biztonsága, 20M Ft bírsággarancia."
  canonical="/rolunk/"
>
  <!-- Hero -->
  <section class="py-16 lg:py-24 bg-gradient-to-br from-teal-light to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="font-heading font-bold text-4xl lg:text-5xl text-heading">Rólunk</h1>
        <p class="mt-4 text-lg text-body leading-relaxed">
          Az Aurapro Kft. Magyarország egyik vezető munka-, tűz- és környezetvédelmi szolgáltatója.
          13 éve segítjük partnereinket a jogszabályi megfelelésben – egyetlen ügyfelünk sem kapott bírságot.
        </p>
      </div>
    </div>
  </section>

  <!-- Számok -->
  <section class="py-12 lg:py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-5 gap-8 text-center">
        {[
          { number: '13+', label: 'év tapasztalat' },
          { number: '30', label: 'szakértő országszerte' },
          { number: '15.000+', label: 'munkavállaló biztonsága' },
          { number: '48+', label: 'nagyvállalati partner' },
          { number: '0', label: 'bírság eddig' },
        ].map((stat, i) => (
          <div data-animate data-animate-delay={i + 1}>
            <div class="font-heading font-bold text-3xl lg:text-4xl text-teal">{stat.number}</div>
            <div class="mt-1 text-muted text-sm">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Kik vagyunk -->
  <section class="py-16 lg:py-20 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="grid lg:grid-cols-5 gap-10 items-start mb-12">
          <div class="lg:col-span-3">
            <h2 class="font-heading font-bold text-3xl text-heading mb-8">Miért az Aurapro?</h2>
          </div>
          <div class="lg:col-span-2 hidden lg:block">
            <img src="/images/aurapro-bemutato.jpg" alt="Aurapro Kft. bemutató" class="rounded-xl shadow-lg border border-border" loading="lazy" />
          </div>
        </div>
        <div class="space-y-6 text-body leading-relaxed">
          <p>
            Cégünket azzal a meggyőződéssel alapítottuk, hogy a munkavédelem nem csupán bürokratikus
            kötelezettség, hanem a dolgozók életét és egészségét védő, valós értéket teremtő tevékenység.
            Ma 30 szakértőnk gondoskodik több mint 15.000 munkavállaló biztonságáról az ország egész területén.
          </p>
          <p>
            Legalább 100 fős cégekre specializálódtunk, ahol a komplex munkavédelmi feladatok kezelése
            valódi szakértelmet és dedikált figyelmet igényel. Partnereink között megtalálhatók a legnagyobb
            magyar és multinacionális vállalatok – az Auditól a Siemensig, a Richtertől a Primarkig.
          </p>
          <p>
            Annyira bízunk a munkánkban, hogy egyedülálló garanciát vállalunk:
            <strong>20 millió Ft bírsággaranciát</strong> adunk minden partnerünknek.
            Ez nem csupán ígéret – szakmai felelősségbiztosításunk fedezi.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Értékeink -->
  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading font-bold text-3xl text-heading text-center mb-12">Hogyan dolgozunk?</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-5xl mx-auto">
        {[
          {
            title: 'Fix átalánydíj',
            desc: 'Kiszámítható, havi fix díj – nincs rejtett költség, a kockázatértékelés és az oktatás az ár részét képezi.',
            icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
          },
          {
            title: 'Országos lefedettség',
            desc: 'Minden megyében jelen vagyunk – gyors helyszíni reakció, helyi hatósági ismeretek.',
            icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z',
          },
          {
            title: 'Dedikált szakértő',
            desc: 'Minden partnerünkhöz kijelölt kapcsolattartó tartozik, aki ismeri a cég sajátosságait.',
            icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z',
          },
          {
            title: 'Komplex szolgáltatás',
            desc: 'Munkavédelem, tűzvédelem és környezetvédelem egy kézből – kevesebb koordináció, több hatékonyság.',
            icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
          },
          {
            title: 'Gyors reagálás',
            desc: 'Hatósági ellenőrzés, munkabaleset, azonnali probléma – szakértőink gyorsan és hatékonyan reagálnak.',
            icon: 'M13 10V3L4 14h7v7l9-11h-7z',
          },
          {
            title: '20M Ft bírsággarancia',
            desc: 'Ha partnerünket bírság éri a mi mulasztásunk miatt, a bírság összegét megtérítjük – biztosítással fedezve.',
            icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
          },
        ].map((item) => (
          <div class="flex gap-4" data-animate>
            <div class="shrink-0 w-12 h-12 rounded-lg bg-teal-light flex items-center justify-center">
              <svg class="w-6 h-6 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon}/>
              </svg>
            </div>
            <div>
              <h3 class="font-heading font-semibold text-heading">{item.title}</h3>
              <p class="mt-1 text-body text-sm">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Székhely -->
  <section class="py-16 lg:py-20 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-heading font-bold text-3xl text-heading mb-8">Elérhetőségek</h2>
        <div class="grid md:grid-cols-2 gap-8">
          <div class="space-y-4">
            <div class="flex gap-3">
              <svg class="w-5 h-5 text-teal shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              <div>
                <p class="font-heading font-semibold text-heading">Székhely</p>
                <p class="text-body text-sm">2040 Budaörs, Gyár utca 2.</p>
                <p class="text-muted text-sm">BITEP Ipari Park</p>
              </div>
            </div>
            <div class="flex gap-3">
              <svg class="w-5 h-5 text-teal shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              <div>
                <p class="font-heading font-semibold text-heading">Telefon</p>
                <a href="tel:+36704098764" class="text-teal hover:text-teal-dark transition-colors">+36 70 409 8764</a>
              </div>
            </div>
            <div class="flex gap-3">
              <svg class="w-5 h-5 text-teal shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              <div>
                <p class="font-heading font-semibold text-heading">Email</p>
                <a href="mailto:info@aurapro.hu" class="text-teal hover:text-teal-dark transition-colors">info@aurapro.hu</a>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl border border-border p-6">
            <p class="font-heading font-semibold text-heading mb-3">Ajánlatkérés</p>
            <p class="text-body text-sm mb-4">Kérjen ingyenes felmérést! 24 órán belül személyre szabott ajánlatot küldünk.</p>
            <a href="/kapcsolat/" class="inline-flex items-center px-6 py-3 bg-orange text-white font-heading font-semibold rounded-lg hover:bg-orange-dark transition-colors">
              Ajánlat kérése
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <ContactForm inline />
</PageLayout>
