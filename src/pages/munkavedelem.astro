---
import PageLayout from '../layouts/PageLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import FaqAccordion from '../components/FaqAccordion.astro';

const services = [
  { title: 'Kockázatértékelés', desc: 'Munkakörönkénti kockázatelemzés, intézkedési terv készítése a jogszabályi megfeleléshez.' },
  { title: 'Munkavédelmi oktatás', desc: 'Éves és rendkívüli oktatások szervezése, dokumentálása – akár online formában is.' },
  { title: 'Munkavédelmi szabályzatok', desc: 'Egyedi szabályzatok készítése: munkavédelmi szabályzat, üzemeltetési dokumentáció, munkautasítások.' },
  { title: 'Munkavédelmi koordinátor', desc: 'Kijelölt szakértő, aki rendszeresen felügyeli a munkavédelmi megfelelést és kapcsolatot tart a hatóságokkal.' },
  { title: 'Hatósági ügyintézés', desc: 'Teljes körű képviselet munkavédelmi hatósági ellenőrzéseknél és eljárásoknál.' },
  { title: 'Munkabalesetek kivizsgálása', desc: 'Baleseti jegyzőkönyv készítése, intézkedési terv, hatósági bejelentések lebonyolítása.' },
];

const faqItems = [
  { question: 'Mikor kötelező munkavédelmi szakembert alkalmazni?', answer: 'Minden munkáltató köteles munkavédelmi feladatokról gondoskodni, ha legalább egy munkavállalót foglalkoztat. A feladatok ellátása megbízott szakértőn keresztül is történhet.' },
  { question: 'Milyen gyakran kell munkavédelmi oktatást tartani?', answer: 'Legalább évente egyszer, valamint munkakör-változás, új technológia bevezetése vagy munkabaleset esetén soron kívül.' },
  { question: 'Mi történik munkavédelmi ellenőrzésnél, ha nincs szabályzatunk?', answer: 'A hatóság bírságot szabhat ki 50.000 Ft-tól 10 millió Ft-ig, és azonnali intézkedéseket rendelhet el.' },
];
---

<PageLayout
  title="Munkavédelem – Aurapro | Kockázatértékelés, oktatás, szabályzatok"
  description="Komplex munkavédelmi szolgáltatás: kockázatértékelés, oktatás, szabályzatok, koordinátor, hatósági képviselet. 10M Ft bírsággarancia."
  canonical="/munkavedelem/"
>
  <!-- Page hero -->
  <section class="py-16 lg:py-24 bg-gradient-to-br from-teal-light to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="font-heading font-bold text-4xl lg:text-5xl text-heading">Munkavédelem</h1>
        <p class="mt-4 text-lg text-body leading-relaxed">
          Teljes körű munkavédelmi szolgáltatás – a kockázatértékeléstől a hatósági képviseletig.
          30 szakértőnk országszerte biztosítja cége jogszabályi megfelelését.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="/kapcsolat/" class="inline-flex items-center px-8 py-4 bg-orange text-white font-heading font-bold rounded-lg hover:bg-orange-dark transition-colors">
            Ingyenes ajánlat kérése
          </a>
          <a href="tel:+3612345678" class="inline-flex items-center px-8 py-4 border-2 border-teal text-teal font-heading font-bold rounded-lg hover:bg-teal hover:text-white transition-colors">
            Hívjon most
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services grid -->
  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading font-bold text-3xl lg:text-4xl text-heading text-center mb-12">Munkavédelmi szolgáltatásaink</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((s) => (
          <div class="bg-surface rounded-xl p-6 border border-border">
            <div class="w-10 h-10 rounded-lg bg-teal-light flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <h3 class="font-heading font-semibold text-heading">{s.title}</h3>
            <p class="mt-2 text-body text-sm leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Guarantee band -->
  <section class="py-12 lg:py-16 bg-teal-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading font-bold text-2xl lg:text-3xl text-white">10 millió Ft bírsággarancia</h2>
      <p class="mt-3 text-white/80 text-lg max-w-2xl mx-auto">
        Annyira bízunk a munkánkban, hogy vállaljuk: ha partnerünket bírság éri a mi mulasztásunk miatt,
        a bírság összegét megtérítjük – 10 millió Ft-ig.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading font-bold text-3xl text-heading text-center mb-10">Gyakori kérdések a munkavédelemről</h2>
      <div class="max-w-3xl mx-auto">
        <FaqAccordion items={faqItems} />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <ContactForm inline />
</PageLayout>
