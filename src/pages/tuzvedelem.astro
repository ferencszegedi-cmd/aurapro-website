---
import PageLayout from '../layouts/PageLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import FaqAccordion from '../components/FaqAccordion.astro';

const services = [
  { title: 'Tűzvédelmi szabályzat', desc: 'Jogszabálynak megfelelő tűzvédelmi szabályzat készítése és naprakészen tartása.' },
  { title: 'Tűzriadó terv', desc: 'Kiürítési terv készítése, menekülési útvonalak kijelölése, tűzriadó gyakorlat szervezése.' },
  { title: 'Tűzvédelmi oktatás', desc: 'Általános és munkaköri tűzvédelmi oktatások – éves rendszerességgel, dokumentáltan.' },
  { title: 'Tűzvédelmi felülvizsgálatok', desc: 'Tűzoltó készülékek, beépített jelző- és oltórendszerek, villamos hálózat felülvizsgálata.' },
  { title: 'Tervezés és engedélyeztetés', desc: 'Tűzvédelmi tervdokumentáció, hatósági engedélyeztetés új épületeknél és átalakításoknál.' },
  { title: 'Hatósági képviselet', desc: 'Katasztrófavédelmi ellenőrzéseknél teljes körű képviselet és ügyintézés.' },
];

const faqItems = [
  { question: 'Mikor kötelező a tűzvédelmi szabályzat?', answer: 'Ha a cég ötvennél több munkavállalót foglalkoztat, 50 főnél nagyobb befogadóképességű helyiséget vagy 10 fő feletti kereskedelmi szálláshelyet üzemeltet (1996. évi XXXI. tv. 19. §).' },
  { question: 'Milyen gyakran kell tűzoltó készüléket felülvizsgálni?', answer: 'Alapfelülvizsgálat évente, középfelülvizsgálat 5 évente, teljes felülvizsgálat (csere/próbanyomás) 10 évente szükséges.' },
  { question: 'Ki tarthat tűzvédelmi oktatást?', answer: 'Tűzvédelmi oktatást a tűzvédelmi szabályzatban kijelölt személy tarthat – ez lehet megbízott külső szakértő is.' },
];

// P0-4: Service + FAQPage JSON-LD
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Tűzvédelmi szolgáltatás',
  provider: { '@type': 'Organization', name: 'Aurapro Kft.', url: 'https://www.aurapro.hu' },
  areaServed: { '@type': 'Country', name: 'Hungary' },
  description: 'Tűzvédelmi szolgáltatás: szabályzat, tűzriadó terv, felülvizsgálat, oktatás, tervezés, katasztrófavédelmi képviselet.',
  url: 'https://www.aurapro.hu/tuzvedelem/',
};
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
---

<PageLayout
  title="Tűzvédelem cégeknek – szabályzat, oktatás | Aurapro"
  description="Tűzvédelmi szabályzat, tűzriadó terv, felülvizsgálatok, oktatás egy kézből. Katasztrófavédelmi ellenőrzésre felkészítünk. Tudjon meg többet."
  canonical="/tuzvedelem/"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)} />

  <!-- Page hero -->
  <section class="py-16 lg:py-24 bg-gradient-to-br from-orange-light to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="font-heading font-bold text-4xl lg:text-5xl text-heading">Tűzvédelem</h1>
        <p class="mt-4 text-lg text-body leading-relaxed">
          A tűzvédelmi szabályzattól a felülvizsgálatokig és hatósági engedélyeztetésig –
          minden egy kézből, katasztrófavédelmi ellenőrzésre felkészítve.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="/kapcsolat/" class="inline-flex items-center px-8 py-4 bg-orange text-white font-heading font-bold rounded-lg hover:bg-orange-dark transition-colors">
            Ingyenes ajánlat kérése
          </a>
          <div class="inline-flex flex-col items-center px-8 py-4 border-2 border-teal text-teal font-heading font-bold rounded-lg">
            <span>Hívjon most</span>
            <span class="text-[1.1rem] font-normal text-teal/80 mt-1">+36 70 409 8764</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services grid -->
  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading font-bold text-3xl lg:text-4xl text-heading text-center mb-12">Tűzvédelmi szolgáltatásaink</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((s) => (
          <div class="bg-surface rounded-xl p-6 border border-border">
            <div class="w-10 h-10 rounded-lg bg-orange-light flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-orange-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/>
              </svg>
            </div>
            <h3 class="font-heading font-semibold text-heading">{s.title}</h3>
            <p class="mt-2 text-body text-sm leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Warning band -->
  <section class="py-12 lg:py-16 bg-teal-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading font-bold text-2xl lg:text-3xl text-white">A katasztrófavédelem bármikor jöhet</h2>
      <p class="mt-3 text-white/80 text-lg max-w-2xl mx-auto">
        Tűzvédelmi hiányosságért akár azonnali bezáratás és több milliós bírság is járhat.
        Partnereinknek nem kell ettől tartaniuk.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading font-bold text-3xl text-heading text-center mb-10">Gyakori kérdések a tűzvédelemről</h2>
      <div class="max-w-3xl mx-auto">
        <FaqAccordion items={faqItems} />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <ContactForm inline />
</PageLayout>
